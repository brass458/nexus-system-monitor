<?xml version="1.0" encoding="utf-8"?>
<!--
  Linux x64 CLI — Self-contained portable build
  Usage: dotnet publish src/NexusMonitor.CLI /p:PublishProfile=cli-linux-x64
  Output: src/NexusMonitor.CLI/publish/cli-linux-x64/
  Package: tar -czf NexusCLI-linux-x64.tar.gz -C publish/cli-linux-x64 .
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <RuntimeIdentifier>linux-x64</RuntimeIdentifier>
    <TargetFramework>net8.0</TargetFramework>
    <SelfContained>true</SelfContained>
    <PublishReadyToRun>true</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishDir>publish/cli-linux-x64/</PublishDir>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <StripSymbols>true</StripSymbols>
    <!-- Strip WINDOWS if cross-compiling from a Windows host -->
    <DefineConstants>$(DefineConstants.Replace(';WINDOWS', '').Replace('WINDOWS;', '').Replace('WINDOWS', ''));LINUX</DefineConstants>
  </PropertyGroup>
</Project>
