<?xml version="1.0" encoding="utf-8"?>
<!--
  Windows ARM64 CLI — Self-contained portable build (Surface Pro X, Snapdragon laptops)
  Usage: dotnet publish src/NexusMonitor.CLI /p:PublishProfile=cli-win-arm64
  Output: src/NexusMonitor.CLI/publish/cli-win-arm64/
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <RuntimeIdentifier>win-arm64</RuntimeIdentifier>
    <TargetFramework>net8.0-windows10.0.17763.0</TargetFramework>
    <SelfContained>true</SelfContained>
    <PublishReadyToRun>true</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishDir>publish\cli-win-arm64\</PublishDir>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
  </PropertyGroup>
</Project>
