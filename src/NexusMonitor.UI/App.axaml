<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NexusMonitor.UI.App"
             RequestedThemeVariant="Dark">

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
    <StyleInclude Source="avares://NexusMonitor/Themes/NexusTheme.axaml" />

    <!-- Liquid Glass text readability: drop shadow on all TextBlocks when glass is active,
         so content-area text stays legible against any wallpaper bleeding through.
         DataGridCell TextBlocks are explicitly excluded — the DataGrid has 1200+ cells and
         applying Gaussian blur to each would devastate frame rate.
         GlassTextEffect = DropShadowEffect when glass enabled, null when disabled. -->
    <Style Selector="TextBlock">
      <Setter Property="Effect" Value="{DynamicResource GlassTextEffect}" />
    </Style>
    <Style Selector="DataGridCell TextBlock">
      <Setter Property="Effect" Value="{x:Null}" />
    </Style>
  </Application.Styles>

</Application>
