<?xml version="1.0" encoding="utf-8"?>
<!--
  Linux x64 — Self-contained portable build
  NOTE: For AppImage creation, install Avalonia.Packaging globally.
  Usage: dotnet publish src/NexusMonitor.UI /p:PublishProfile=linux-x64
  Output: src/NexusMonitor.UI/publish/linux-x64/
  Tar the output directory for distribution:
    tar -czf NexusMonitor-linux-x64.tar.gz -C publish/linux-x64 .
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <RuntimeIdentifier>linux-x64</RuntimeIdentifier>
    <TargetFramework>net8.0</TargetFramework>
    <SelfContained>true</SelfContained>
    <PublishReadyToRun>true</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishDir>publish/linux-x64/</PublishDir>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <StripSymbols>true</StripSymbols>
  </PropertyGroup>
</Project>
