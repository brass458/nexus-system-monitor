<?xml version="1.0" encoding="utf-8"?>
<!--
  Linux ARM64 — Self-contained portable build (Raspberry Pi 4+, AWS Graviton, etc.)
  Usage: dotnet publish src/NexusMonitor.UI /p:PublishProfile=linux-arm64
  Output: src/NexusMonitor.UI/publish/linux-arm64/
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <RuntimeIdentifier>linux-arm64</RuntimeIdentifier>
    <TargetFramework>net8.0</TargetFramework>
    <SelfContained>true</SelfContained>
    <PublishReadyToRun>false</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishDir>publish/linux-arm64/</PublishDir>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <StripSymbols>true</StripSymbols>
    <DefineConstants>$(DefineConstants);LINUX</DefineConstants>
  </PropertyGroup>
</Project>
