<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Font families — Inter (bundled via Avalonia.Fonts.Inter) as primary, platform fallbacks -->
  <FontFamily x:Key="FontSans">Inter,Segoe UI Variable,Segoe UI,Helvetica Neue,Arial,sans-serif</FontFamily>
  <FontFamily x:Key="FontMono">Cascadia Code,JetBrains Mono,Consolas,Menlo,monospace</FontFamily>
  <!-- Icon font — Fluent System Icons (MIT, cross-platform, bundled) -->
  <FontFamily x:Key="NexusIcons">avares://NexusMonitor/Assets/Fonts/FluentSystemIcons-Regular.ttf#FluentSystemIcons-Regular</FontFamily>

  <!-- ===== STATIC FONT SIZE SCALE =====
       Base: 14px body — comfortable for modern displays.
       Hierarchy goes from 11px compact labels up to 28px hero numbers. -->

  <!-- Legacy semantic tokens (used by a few older layouts) -->
  <x:Double x:Key="FontSizeXS">12</x:Double>
  <x:Double x:Key="FontSizeSM">13</x:Double>
  <x:Double x:Key="FontSizeMD">14</x:Double>
  <x:Double x:Key="FontSizeBase">15</x:Double>
  <x:Double x:Key="FontSizeLG">17</x:Double>
  <x:Double x:Key="FontSizeXL">19</x:Double>
  <x:Double x:Key="FontSize2XL">23</x:Double>
  <x:Double x:Key="FontSize3XL">30</x:Double>

  <!-- NxFont* tokens — referenced throughout all views and control styles.
       All values bumped +1px vs original: makes text slightly larger overall and
       provides headroom so fonts with smaller x-heights (e.g. Segoe UI, Calibri)
       appear at a reasonable size when the user switches from the default Inter. -->
  <x:Double x:Key="NxFont10">12</x:Double>
  <x:Double x:Key="NxFont11">13</x:Double>
  <x:Double x:Key="NxFont12">14</x:Double>
  <x:Double x:Key="NxFont13">15</x:Double>
  <x:Double x:Key="NxFont14">16</x:Double>
  <x:Double x:Key="NxFont16">18</x:Double>
  <x:Double x:Key="NxFont18">21</x:Double>
  <x:Double x:Key="NxFont24">30</x:Double>

  <!-- Control-style shorthand aliases -->
  <x:Double x:Key="NxFontSm">13</x:Double>
  <x:Double x:Key="NxFontBase">14</x:Double>
  <x:Double x:Key="NxFontMd">15</x:Double>

  <!-- Corner radii — generous Apple-style rounding -->
  <CornerRadius x:Key="CornerSM">8</CornerRadius>
  <CornerRadius x:Key="CornerMD">10</CornerRadius>
  <CornerRadius x:Key="CornerLG">14</CornerRadius>
  <CornerRadius x:Key="CornerXL">20</CornerRadius>
  <CornerRadius x:Key="CornerFull">9999</CornerRadius>

  <!-- Padding tokens -->
  <Thickness x:Key="PaddingXS">4</Thickness>
  <Thickness x:Key="PaddingSM">8</Thickness>
  <Thickness x:Key="PaddingMD">12</Thickness>
  <Thickness x:Key="PaddingLG">16</Thickness>
  <Thickness x:Key="PaddingXL">24</Thickness>

</ResourceDictionary>
