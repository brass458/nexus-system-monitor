<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Font families — Inter (bundled via Avalonia.Fonts.Inter) as primary, platform fallbacks -->
  <FontFamily x:Key="FontSans">Inter,Segoe UI Variable,Segoe UI,Helvetica Neue,Arial,sans-serif</FontFamily>
  <FontFamily x:Key="FontMono">Cascadia Code,JetBrains Mono,Consolas,Menlo,monospace</FontFamily>

  <!-- ===== STATIC FONT SIZE SCALE =====
       These are the canonical font sizes for the app. All views reference the
       NxFont* tokens below via {DynamicResource} so they apply instantly.
       Base: 14px body — comfortable for any modern display density. -->

  <!-- Legacy semantic tokens (used by a few older layouts) -->
  <x:Double x:Key="FontSizeXS">12</x:Double>
  <x:Double x:Key="FontSizeSM">12</x:Double>
  <x:Double x:Key="FontSizeMD">13</x:Double>
  <x:Double x:Key="FontSizeBase">14</x:Double>
  <x:Double x:Key="FontSizeLG">15</x:Double>
  <x:Double x:Key="FontSizeXL">17</x:Double>
  <x:Double x:Key="FontSize2XL">22</x:Double>
  <x:Double x:Key="FontSize3XL">26</x:Double>

  <!-- NxFont* tokens — referenced throughout all views and control styles.
       No longer written at runtime; defined here so {DynamicResource} always resolves. -->
  <x:Double x:Key="NxFont10">12</x:Double>
  <x:Double x:Key="NxFont11">12</x:Double>
  <x:Double x:Key="NxFont12">13</x:Double>
  <x:Double x:Key="NxFont13">14</x:Double>
  <x:Double x:Key="NxFont14">15</x:Double>
  <x:Double x:Key="NxFont16">17</x:Double>

  <!-- Control-style shorthand aliases -->
  <x:Double x:Key="NxFontSm">12</x:Double>
  <x:Double x:Key="NxFontBase">13</x:Double>
  <x:Double x:Key="NxFontMd">14</x:Double>

  <!-- Corner radii -->
  <CornerRadius x:Key="CornerSM">6</CornerRadius>
  <CornerRadius x:Key="CornerMD">8</CornerRadius>
  <CornerRadius x:Key="CornerLG">12</CornerRadius>
  <CornerRadius x:Key="CornerXL">16</CornerRadius>
  <CornerRadius x:Key="CornerFull">9999</CornerRadius>

  <!-- Padding tokens -->
  <Thickness x:Key="PaddingXS">4</Thickness>
  <Thickness x:Key="PaddingSM">8</Thickness>
  <Thickness x:Key="PaddingMD">12</Thickness>
  <Thickness x:Key="PaddingLG">16</Thickness>
  <Thickness x:Key="PaddingXL">24</Thickness>

</ResourceDictionary>
