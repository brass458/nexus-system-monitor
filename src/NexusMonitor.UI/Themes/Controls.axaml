<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ===== BUTTON — Elevated ===== -->
  <Style Selector="Button.nx-btn">
    <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="14,7" />
    <Setter Property="FontSize" Value="{DynamicResource NxFontMd}" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.nx-btn /template/ ContentPresenter">
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.15"/>
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Button.nx-btn:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource BgHoverBrush}" />
  </Style>
  <Style Selector="Button.nx-btn:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource BgSelectedBrush}" />
  </Style>

  <!-- ===== BUTTON — Accent (Primary action) ===== -->
  <Style Selector="Button.nx-btn-accent">
    <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="14,7" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.nx-btn-accent /template/ ContentPresenter">
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.15"/>
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Button.nx-btn-accent:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBlueHoverBrush}" />
  </Style>

  <!-- ===== BUTTON — Ghost (Transparent) ===== -->
  <Style Selector="Button.nx-btn-ghost">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.nx-btn-ghost /template/ ContentPresenter">
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.15"/>
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Button.nx-btn-ghost:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource BgHoverBrush}" />
  </Style>

  <!-- Active nav item — accent pill background + accent text + bold -->
  <Style Selector="Button.nx-btn-ghost.active">
    <Setter Property="Foreground" Value="{DynamicResource AccentBlueBrush}" />
  </Style>
  <Style Selector="Button.nx-btn-ghost.active /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBlueDimBrush}" />
  </Style>
  <Style Selector="Button.nx-btn-ghost.active TextBlock">
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <!-- ===== TEXT INPUT ===== -->
  <Style Selector="TextBox.nx-input">
    <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="FontSize" Value="{DynamicResource NxFontMd}" />
    <Setter Property="SelectionBrush" Value="{DynamicResource AccentBlueDimBrush}" />
    <Setter Property="CaretBrush" Value="{DynamicResource AccentBlueBrush}" />
  </Style>
  <Style Selector="TextBox.nx-input:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
  </Style>

  <!-- ===== SCROLLBAR ===== -->
  <Style Selector="ScrollBar">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Opacity" Value="0.5" />
  </Style>
  <Style Selector="ScrollBar /template/ Thumb">
    <Setter Property="Background" Value="{DynamicResource BorderDefaultBrush}" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="MinHeight" Value="20" />
    <Setter Property="MinWidth" Value="3" />
  </Style>

  <!-- ===== DATA GRID ===== -->
  <Style Selector="DataGrid.nx-grid">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="RowBackground" Value="Transparent" />
    <Setter Property="GridLinesVisibility" Value="None" />
    <Setter Property="HeadersVisibility" Value="Column" />
    <Setter Property="FontSize" Value="{DynamicResource NxFontBase}" />
  </Style>
  <Style Selector="DataGrid.nx-grid DataGridColumnHeader">
    <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource DataGridHeaderFgBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="Padding" Value="10,9" />
    <Setter Property="FontSize" Value="{DynamicResource NxFontSm}" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="MinHeight" Value="36" />
  </Style>
  <Style Selector="DataGrid.nx-grid DataGridRow /template/ Rectangle#BackgroundRectangle">
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Fill" Duration="0:0:0.12"/>
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="DataGrid.nx-grid DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
    <Setter Property="Fill" Value="{DynamicResource BgHoverBrush}" />
  </Style>
  <Style Selector="DataGrid.nx-grid DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
    <Setter Property="Fill" Value="{DynamicResource AccentBlueDimBrush}" />
  </Style>
  <Style Selector="DataGrid.nx-grid DataGridRow">
    <Setter Property="MinHeight" Value="32" />
  </Style>
  <Style Selector="DataGrid.nx-grid DataGridCell">
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource DataGridCellFgBrush}" />
    <Setter Property="FontSize" Value="{DynamicResource NxFontSm}" />
  </Style>

  <!-- ===== LIST BOX ===== -->
  <Style Selector="ListBox.nx-list">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
  </Style>
  <Style Selector="ListBox.nx-list ListBoxItem">
    <Setter Property="Padding" Value="10,7" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Margin" Value="2,1" />
  </Style>
  <Style Selector="ListBox.nx-list ListBoxItem /template/ ContentPresenter">
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.12"/>
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="ListBox.nx-list ListBoxItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource BgHoverBrush}" />
  </Style>
  <Style Selector="ListBox.nx-list ListBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBlueDimBrush}" />
  </Style>

  <!-- ===== CONTEXT MENU ===== -->
  <!--
    Background and border use DynamicResource so both adapt to Light/Dark theme.
    ContextMenuBgBrush and ContextMenuBorderBrush are defined in Colors.axaml
    ThemeDictionaries with ~94% opaque fills so they stay visible regardless of
    glass opacity settings.
  -->
  <Style Selector="ContextMenu">
    <Setter Property="BorderBrush" Value="{DynamicResource ContextMenuBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="5" />
    <Setter Property="Background" Value="{DynamicResource ContextMenuBgBrush}" />
  </Style>
  <Style Selector="MenuItem">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="FontSize" Value="{DynamicResource NxFontBase}" />
    <Setter Property="CornerRadius" Value="8" />
  </Style>
  <Style Selector="MenuItem:pointerover /template/ Border#root">
    <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}" />
    <Setter Property="CornerRadius" Value="8" />
  </Style>
  <Style Selector="MenuItem:pointerover">
    <Setter Property="Foreground" Value="White" />
  </Style>
  <!-- Separator styling -->
  <Style Selector="Separator">
    <Setter Property="Background" Value="{DynamicResource SeparatorBrush}" />
    <Setter Property="Height" Value="1" />
    <Setter Property="Margin" Value="8,4" />
  </Style>

  <!-- ===== TOGGLE BUTTON ===== -->
  <Style Selector="ToggleButton.nx-toggle">
    <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="9999" />
    <Setter Property="Padding" Value="14,6" />
    <Setter Property="FontSize" Value="{DynamicResource NxFontSm}" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="ToggleButton.nx-toggle /template/ ContentPresenter">
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.2"/>
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="ToggleButton.nx-toggle:checked">
    <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
  <Style Selector="ToggleButton.nx-toggle:checked:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBlueHoverBrush}" />
  </Style>

  <!-- ===== TOOL TIP ===== -->
  <Style Selector="ToolTip">
    <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="FontSize" Value="{DynamicResource NxFontSm}" />
  </Style>

  <!-- ===== PROCESS DETAIL PANEL LABELS ===== -->
  <Style Selector="TextBlock.detail-label">
    <Setter Property="FontSize" Value="{DynamicResource NxFont10}" />
    <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}" />
    <Setter Property="VerticalAlignment" Value="Top" />
    <Setter Property="Margin" Value="0,4,12,4" />
    <Setter Property="MinWidth" Value="72" />
  </Style>
  <Style Selector="TextBlock.detail-value">
    <Setter Property="FontSize" Value="{DynamicResource NxFont11}" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="VerticalAlignment" Value="Top" />
    <Setter Property="Margin" Value="0,4,0,4" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <!-- ===== DATAGRID — column sizing ===== -->
  <Style Selector="DataGrid">
    <Setter Property="UseLayoutRounding" Value="True"/>
  </Style>
  <Style Selector="DataGridColumnHeader">
    <Setter Property="MinWidth" Value="60"/>
  </Style>

</Styles>
