<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             xmlns:conv="using:NexusMonitor.UI.Converters"
             x:Class="NexusMonitor.UI.Views.NetworkView"
             x:DataType="vm:NetworkViewModel"
             x:CompileBindings="False">

  <UserControl.Resources>
    <conv:TcpStateBrushConverter x:Key="TcpStateBrush"/>
    <conv:TcpStateLabelConverter x:Key="TcpStateLabel"/>
    <conv:NullToBoolConverter x:Key="NullToBool"/>
  </UserControl.Resources>

  <DockPanel>

    <!-- Toolbar -->
    <Border DockPanel.Dock="Top"
            Padding="16,10"
            Background="{StaticResource BgSecondaryBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left"
                   Text="Network Connections"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   VerticalAlignment="Center"
                   Margin="0,0,16,0"/>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <ToggleButton Classes="nx-toggle"
                        IsChecked="{Binding IsDetailPanelVisible}"
                        ToolTip.Tip="Show/hide connection details panel">
            <TextBlock Text="Details" FontSize="11"/>
          </ToggleButton>
          <TextBox Classes="nx-input"
                   Text="{Binding SearchText}"
                   Watermark="Search address, port, process&#x2026;"
                   Width="260"
                   VerticalAlignment="Center"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Status bar -->
    <Border DockPanel.Dock="Bottom"
            Padding="16,6"
            Background="{StaticResource BgSecondaryBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="0,1,0,0">
      <TextBlock Text="{Binding TotalCount, StringFormat='Connections: {0}'}"
                 FontSize="11"
                 Foreground="{StaticResource TextSecondaryBrush}"/>
    </Border>

    <!-- Connection table + sidebar -->
    <Grid ColumnDefinitions="*,Auto,Auto">

      <!-- DataGrid -->
      <DataGrid Grid.Column="0"
                Classes="nx-grid"
                ItemsSource="{Binding Connections}"
                SelectedItem="{Binding SelectedConnection}"
                AutoGenerateColumns="False"
                CanUserSortColumns="True"
                CanUserResizeColumns="True"
                CanUserReorderColumns="True"
                IsReadOnly="True">
        <DataGrid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Copy Local Address"  Command="{Binding CopyLocalAddressCommand}"/>
            <MenuItem Header="Copy Remote Address" Command="{Binding CopyRemoteAddressCommand}"/>
            <Separator/>
            <MenuItem Header="Go to Process" Command="{Binding GoToProcessCommand}"/>
          </ContextMenu>
        </DataGrid.ContextMenu>
        <DataGrid.Columns>
          <DataGridTextColumn Header="Protocol"       Binding="{Binding Protocol}"      Width="80"  IsReadOnly="True"/>
          <DataGridTextColumn Header="Local Address"  Binding="{Binding LocalAddress}"  Width="140" IsReadOnly="True"/>
          <DataGridTextColumn Header="Local Port"     Binding="{Binding LocalPort}"     Width="80"  IsReadOnly="True"/>
          <DataGridTextColumn Header="Remote Address" Binding="{Binding RemoteAddress}" Width="140" IsReadOnly="True"/>
          <DataGridTextColumn Header="Remote Port"    Binding="{Binding RemotePort}"    Width="80"  IsReadOnly="True"/>
          <DataGridTemplateColumn Header="State" Width="130" SortMemberPath="State">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Border CornerRadius="4"
                        Padding="6,2"
                        Margin="4,3"
                        HorizontalAlignment="Left"
                        Background="{Binding State, Converter={StaticResource TcpStateBrush}}">
                  <TextBlock Text="{Binding State, Converter={StaticResource TcpStateLabel}}"
                             FontSize="10" FontWeight="Medium"
                             Foreground="White"/>
                </Border>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="&#x2191; Send"  Binding="{Binding SendDisplay}"   Width="90"  IsReadOnly="True"/>
          <DataGridTextColumn Header="&#x2193; Recv"  Binding="{Binding RecvDisplay}"   Width="90"  IsReadOnly="True"/>
          <DataGridTextColumn Header="PID"            Binding="{Binding ProcessId}"     Width="60"  IsReadOnly="True"/>
          <DataGridTextColumn Header="Process"        Binding="{Binding ProcessName}"   Width="*"   IsReadOnly="True"/>
        </DataGrid.Columns>
      </DataGrid>

      <!-- Splitter -->
      <GridSplitter Grid.Column="1"
                    Width="1"
                    Background="{StaticResource BorderSubtleBrush}"
                    IsVisible="{Binding IsConnectionDetailShown}"/>

      <!-- Detail sidebar -->
      <Border Grid.Column="2"
              Width="260"
              Background="{StaticResource BgSecondaryBrush}"
              IsVisible="{Binding IsConnectionDetailShown}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="0"
                      DataContext="{Binding SelectedConnection}"
                      Margin="14,12">

            <!-- Header: process name -->
            <TextBlock Text="{Binding ProcessName}"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,2"/>
            <TextBlock FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,6">
              <Run Text="PID "/>
              <Run Text="{Binding ProcessId}" FontWeight="Medium" Foreground="{StaticResource TextSecondaryBrush}"/>
            </TextBlock>

            <!-- State badge -->
            <Border CornerRadius="4" Padding="8,3" Margin="0,0,0,10"
                    HorizontalAlignment="Left"
                    Background="{Binding State, Converter={StaticResource TcpStateBrush}}">
              <TextBlock Text="{Binding State, Converter={StaticResource TcpStateLabel}}"
                         FontSize="11" Foreground="White" FontWeight="Medium"/>
            </Border>

            <Separator Background="{StaticResource BorderSubtleBrush}" Margin="0,0,0,10"/>

            <!-- Local endpoint -->
            <TextBlock Text="LOCAL ENDPOINT" FontSize="9" FontWeight="Medium"
                       Foreground="{StaticResource TextTertiaryBrush}"
                       LetterSpacing="0.8" Margin="0,0,0,6"/>

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Margin="0,0,0,12">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Address" Classes="detail-label"/>
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LocalAddress}" Classes="detail-value"/>
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Port"    Classes="detail-label"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LocalPort}"   Classes="detail-value"/>
            </Grid>

            <!-- Remote endpoint -->
            <TextBlock Text="REMOTE ENDPOINT" FontSize="9" FontWeight="Medium"
                       Foreground="{StaticResource TextTertiaryBrush}"
                       LetterSpacing="0.8" Margin="0,0,0,6"/>

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Margin="0,0,0,12">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Address" Classes="detail-label"/>
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RemoteAddress}" Classes="detail-value"/>
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Port"    Classes="detail-label"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RemotePort}"   Classes="detail-value"/>
            </Grid>

            <!-- Throughput -->
            <TextBlock Text="THROUGHPUT" FontSize="9" FontWeight="Medium"
                       Foreground="{StaticResource TextTertiaryBrush}"
                       LetterSpacing="0.8" Margin="0,0,0,6"/>

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" Margin="0,0,0,12">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Protocol" Classes="detail-label"/>
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Protocol}"    Classes="detail-value"/>
              <TextBlock Grid.Row="1" Grid.Column="0" Text="&#x2191; Send" Classes="detail-label"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SendDisplay}" Classes="detail-value"
                         Foreground="{DynamicResource AccentBlueBrush}"/>
              <TextBlock Grid.Row="2" Grid.Column="0" Text="&#x2193; Recv" Classes="detail-label"/>
              <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RecvDisplay}" Classes="detail-value"
                         Foreground="{DynamicResource AccentBlueBrush}"/>
            </Grid>

          </StackPanel>
        </ScrollViewer>
      </Border>

    </Grid>

  </DockPanel>

</UserControl>
