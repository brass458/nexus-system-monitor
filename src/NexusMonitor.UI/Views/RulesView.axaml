<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             x:Class="NexusMonitor.UI.Views.RulesView"
             x:DataType="vm:RulesViewModel"
             x:CompileBindings="False">

  <DockPanel>

    <!-- ══ Header ══════════════════════════════════════════════════════════ -->
    <Border DockPanel.Dock="Top"
            Padding="16,10"
            Background="{StaticResource BgSecondaryBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left"
                   Text="Process Rules"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   VerticalAlignment="Center"/>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6">
          <Button Classes="nx-btn"
                  Command="{Binding AddRuleCommand}"
                  ToolTip.Tip="Create a new process rule">
            <TextBlock Text="＋ Add Rule" FontSize="12"/>
          </Button>
          <Button Classes="nx-btn"
                  Command="{Binding EditRuleCommand}"
                  IsEnabled="{Binding SelectedRule, Converter={x:Static ObjectConverters.IsNotNull}}"
                  ToolTip.Tip="Edit the selected rule">
            <TextBlock Text="✏ Edit" FontSize="12"/>
          </Button>
          <Button Classes="nx-btn"
                  Command="{Binding DeleteRuleCommand}"
                  IsEnabled="{Binding SelectedRule, Converter={x:Static ObjectConverters.IsNotNull}}"
                  ToolTip.Tip="Delete the selected rule">
            <TextBlock Text="🗑 Delete" FontSize="12"/>
          </Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ══ Main content ═════════════════════════════════════════════════════ -->
    <Grid ColumnDefinitions="*">

      <!-- Rules list + empty state -->
      <Grid IsVisible="{Binding IsEditorVisible, Converter={x:Static BoolConverters.Not}}">
        <DockPanel>

          <!-- Intro blurb -->
          <Border DockPanel.Dock="Top"
                  Padding="16,10"
                  Background="{DynamicResource BgSecondaryBrush}"
                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                  BorderThickness="0,0,0,1">
            <TextBlock Text="Rules automatically apply priority, affinity, I/O priority, and other settings to matching processes when they launch. Watchdog conditions can act when a process exceeds a threshold."
                       FontSize="11" TextWrapping="Wrap"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
          </Border>

          <!-- Empty state -->
          <Border DockPanel.Dock="Top"
                  Padding="24,48"
                  IsVisible="{Binding Rules.Count, Converter={x:Static BoolConverters.Not}}">
            <StackPanel HorizontalAlignment="Center" Spacing="10">
              <TextBlock Text="📋" FontSize="36" HorizontalAlignment="Center"
                         Foreground="{StaticResource TextTertiaryBrush}"/>
              <TextBlock Text="No rules configured"
                         FontSize="14" FontWeight="SemiBold"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="Click + Add Rule to create your first process rule."
                         FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                         HorizontalAlignment="Center"/>
            </StackPanel>
          </Border>

          <!-- Rule list -->
          <ScrollViewer Padding="16">
            <StackPanel Spacing="6">
              <ItemsControl ItemsSource="{Binding Rules}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Padding="14,12"
                            Margin="0,0,0,1"
                            Background="{DynamicResource BgElevatedBrush}"
                            BorderBrush="{DynamicResource GlassBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerMD}"
                            Cursor="Hand">
                      <Border.Styles>
                        <Style Selector="Border:pointerover">
                          <Setter Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                        </Style>
                      </Border.Styles>
                      <DockPanel>

                        <!-- Enable/disable dot indicator -->
                        <Border DockPanel.Dock="Left"
                                Width="6" Height="6"
                                CornerRadius="3"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0">
                          <Border.Background>
                            <SolidColorBrush Color="{Binding IsEnabled,
                                             Converter={x:Static BoolConverters.Not},
                                             ConverterParameter=#636366}"/>
                          </Border.Background>
                        </Border>

                        <!-- Main info -->
                        <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center"
                                    Spacing="2" Width="200">
                          <TextBlock Text="{Binding Name}"
                                     FontSize="13" FontWeight="SemiBold"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     TextTrimming="CharacterEllipsis"/>
                          <TextBlock Text="{Binding ProcessNamePattern}"
                                     FontSize="11"
                                     FontFamily="Consolas,Courier New,monospace"
                                     Foreground="{DynamicResource AccentBlueBrush}"
                                     TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <!-- Actions summary -->
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{Binding Summary}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="12,0"/>

                        <!-- Edit button -->
                        <Button DockPanel.Dock="Right"
                                Classes="nx-btn"
                                Padding="8,4"
                                FontSize="11"
                                Content="Edit"
                                VerticalAlignment="Center"
                                Command="{Binding DataContext.EditRuleCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Click="OnRuleRowClick"/>

                      </DockPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>

        </DockPanel>
      </Grid>

      <!-- ══ Editor panel (shown when IsEditorVisible) ═══════════════════ -->
      <Border IsVisible="{Binding IsEditorVisible}"
              Background="{DynamicResource BgBaseBrush}">
        <DockPanel>

          <!-- Editor header -->
          <Border DockPanel.Dock="Top"
                  Padding="16,10"
                  Background="{DynamicResource BgSecondaryBrush}"
                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                  BorderThickness="0,0,0,1">
            <DockPanel>
              <TextBlock DockPanel.Dock="Left"
                         Text="{Binding EditorTitle}"
                         FontSize="14" FontWeight="SemiBold"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         VerticalAlignment="Center"/>
              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6">
                <Button Classes="nx-btn"
                        Command="{Binding SaveEditCommand}"
                        ToolTip.Tip="Save this rule">
                  <TextBlock Text="💾 Save" FontSize="12"/>
                </Button>
                <Button Classes="nx-btn"
                        Command="{Binding CancelEditCommand}">
                  <TextBlock Text="Cancel" FontSize="12"/>
                </Button>
              </StackPanel>
            </DockPanel>
          </Border>

          <!-- Validation error -->
          <Border DockPanel.Dock="Top"
                  Padding="16,8"
                  Background="#30FF453A"
                  IsVisible="{Binding ValidationError.Length,
                              Converter={x:Static BoolConverters.Not},
                              ConverterParameter=0}">
            <TextBlock Text="{Binding ValidationError}"
                       FontSize="12" Foreground="{StaticResource ColorDangerBrush}"/>
          </Border>

          <ScrollViewer Padding="16">
            <StackPanel Spacing="16" MaxWidth="740">

              <!-- ── Identity ──────────────────────────────────────────── -->
              <Border Padding="16"
                      Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="{StaticResource CornerLG}">
                <StackPanel Spacing="12">
                  <TextBlock Text="IDENTITY" FontSize="10" FontWeight="Medium"
                             LetterSpacing="0.6" Foreground="{StaticResource TextTertiaryBrush}"/>
                  <Grid ColumnDefinitions="*,14,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="Rule Name" FontSize="12"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                      <TextBox Text="{Binding EditName}" Watermark="My Rule"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="Process Name Pattern *" FontSize="12"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                      <TextBox Text="{Binding EditPattern}"
                               FontFamily="Consolas,Courier New,monospace"
                               Watermark="chrome  or  *helper*"/>
                      <TextBlock Text="Supports * wildcard. Case-insensitive. No .exe needed."
                                 FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"/>
                    </StackPanel>
                  </Grid>
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <CheckBox IsChecked="{Binding EditEnabled}"
                              Content="Rule is enabled"/>
                    <CheckBox IsChecked="{Binding EditDisallowed}"
                              Content="Disallowed (terminate on launch)"
                              Foreground="{StaticResource ColorDangerBrush}"/>
                    <CheckBox IsChecked="{Binding EditKeepRunning}"
                              Content="Keep running (restart on exit)"
                              Foreground="#30D158"/>
                  </StackPanel>
                </StackPanel>
              </Border>

              <!-- ── Persistent Actions ──────────────────────────────── -->
              <Border Padding="16"
                      Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="{StaticResource CornerLG}">
                <StackPanel Spacing="12">
                  <StackPanel Spacing="2">
                    <TextBlock Text="PERSISTENT ACTIONS" FontSize="10" FontWeight="Medium"
                               LetterSpacing="0.6" Foreground="{StaticResource TextTertiaryBrush}"/>
                    <TextBlock Text="Applied every time this process launches."
                               FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"/>
                  </StackPanel>

                  <Grid ColumnDefinitions="*,14,*,14,*">
                    <!-- Priority -->
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="CPU Priority" FontSize="12"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                      <ComboBox ItemsSource="{x:Static vm:RulesViewModel.PriorityOptions}"
                                SelectedIndex="{Binding EditPriorityIndex}"/>
                    </StackPanel>
                    <!-- I/O Priority -->
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="I/O Priority" FontSize="12"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                      <ComboBox ItemsSource="{x:Static vm:RulesViewModel.IoPriorityOptions}"
                                SelectedIndex="{Binding EditIoPriorityIndex}"/>
                    </StackPanel>
                    <!-- Memory Priority -->
                    <StackPanel Grid.Column="4" Spacing="4">
                      <TextBlock Text="Memory Priority" FontSize="12"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                      <ComboBox ItemsSource="{x:Static vm:RulesViewModel.MemPriorityOptions}"
                                SelectedIndex="{Binding EditMemPriorityIndex}"/>
                    </StackPanel>
                  </Grid>

                  <Grid ColumnDefinitions="*,14,*">
                    <!-- Efficiency Mode -->
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="Efficiency Mode (EcoQoS)" FontSize="12"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                      <ComboBox ItemsSource="{x:Static vm:RulesViewModel.EfficiencyOptions}"
                                SelectedIndex="{Binding EditEfficiencyIndex}"/>
                      <TextBlock Text="Windows 11+ EcoQoS: reduces power and heat for background apps."
                                 FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                    <!-- CPU Affinity -->
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="CPU Affinity Mask (hex)" FontSize="12"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                      <TextBox Text="{Binding EditAffinityHex}"
                               FontFamily="Consolas,Courier New,monospace"
                               Watermark="e.g. 0xF  (first 4 cores)"/>
                      <TextBlock Text="Bitmask of allowed CPUs. 0xFF = all 8 cores. Leave blank to keep default."
                                 FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>

              <!-- ── Watchdog Condition ──────────────────────────────── -->
              <Border Padding="16"
                      Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="{StaticResource CornerLG}">
                <StackPanel Spacing="12">
                  <StackPanel Spacing="2">
                    <TextBlock Text="WATCHDOG CONDITION" FontSize="10" FontWeight="Medium"
                               LetterSpacing="0.6" Foreground="{StaticResource TextTertiaryBrush}"/>
                    <TextBlock Text="Action taken when the process exceeds a threshold for a sustained duration."
                               FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"/>
                  </StackPanel>

                  <Grid ColumnDefinitions="*,14,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="Trigger Condition" FontSize="12"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                      <ComboBox ItemsSource="{x:Static vm:RulesViewModel.ConditionTypeOptions}"
                                SelectedIndex="{Binding EditConditionTypeIndex}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="Watchdog Action" FontSize="12"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                      <ComboBox ItemsSource="{x:Static vm:RulesViewModel.WatchdogActionOptions}"
                                SelectedIndex="{Binding EditWatchdogActionIndex}"/>
                    </StackPanel>
                  </Grid>

                  <!-- Condition parameters (shown when condition != Always) -->
                  <Grid ColumnDefinitions="*,14,*,14,*"
                        IsVisible="{Binding IsConditionEnabled}">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="CPU Threshold (%)" FontSize="12"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                      <Grid ColumnDefinitions="*,Auto">
                        <Slider Grid.Column="0" Minimum="1" Maximum="99"
                                Value="{Binding EditConditionCpuThreshold}"
                                IsEnabled="{Binding EditConditionTypeIndex,
                                            Converter={x:Static BoolConverters.Not},
                                            ConverterParameter=0}"/>
                        <TextBlock Grid.Column="1" FontSize="11"
                                   Text="{Binding EditConditionCpuThreshold, StringFormat='{}{0:F0}%'}"
                                   Foreground="{DynamicResource AccentBlueBrush}"
                                   VerticalAlignment="Center" Margin="6,0,0,0"/>
                      </Grid>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="RAM Threshold (MB)" FontSize="12"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                      <Grid ColumnDefinitions="*,Auto">
                        <Slider Grid.Column="0" Minimum="64" Maximum="8192"
                                Value="{Binding EditConditionRamMb}"
                                IsEnabled="{Binding EditConditionTypeIndex,
                                            Converter={x:Static BoolConverters.Not},
                                            ConverterParameter=0}"/>
                        <TextBlock Grid.Column="1" FontSize="11"
                                   Text="{Binding EditConditionRamMb, StringFormat='{}{0:F0} MB'}"
                                   Foreground="{DynamicResource AccentBlueBrush}"
                                   VerticalAlignment="Center" Margin="6,0,0,0"/>
                      </Grid>
                    </StackPanel>
                    <StackPanel Grid.Column="4" Spacing="4">
                      <TextBlock Text="Duration (seconds)" FontSize="12"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                      <NumericUpDown Value="{Binding EditConditionDurationSecs}"
                                     Minimum="1" Maximum="3600" Increment="1"
                                     FormatString="0"/>
                    </StackPanel>
                  </Grid>

                </StackPanel>
              </Border>

            </StackPanel>
          </ScrollViewer>

        </DockPanel>
      </Border>

    </Grid>

  </DockPanel>

</UserControl>
