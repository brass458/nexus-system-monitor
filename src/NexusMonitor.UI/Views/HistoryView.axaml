<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             x:Class="NexusMonitor.UI.Views.HistoryView"
             x:DataType="vm:HistoryViewModel"
             x:CompileBindings="False">

  <Grid RowDefinitions="Auto,*">

    <!-- ===== TOOLBAR ===== -->
    <Border Grid.Row="0"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{StaticResource GlassBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="16,10">
      <Grid ColumnDefinitions="*,Auto">

        <!-- Range selector -->
        <StackPanel Orientation="Horizontal" Spacing="4">
          <TextBlock Text="Range:"
                     FontSize="{DynamicResource NxFont12}"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     VerticalAlignment="Center"
                     Margin="0,0,6,0"/>
          <Button Classes="nx-btn-ghost" Classes.active="{Binding Is1hActive}"
                  Command="{Binding Load1hCommand}"
                  Padding="12,6" CornerRadius="8"
                  ToolTip.Tip="Last 1 hour (raw data)">
            <TextBlock Text="1h" FontSize="{DynamicResource NxFont12}"/>
          </Button>
          <Button Classes="nx-btn-ghost" Classes.active="{Binding Is6hActive}"
                  Command="{Binding Load6hCommand}"
                  Padding="12,6" CornerRadius="8"
                  ToolTip.Tip="Last 6 hours (1-min rollups)">
            <TextBlock Text="6h" FontSize="{DynamicResource NxFont12}"/>
          </Button>
          <Button Classes="nx-btn-ghost" Classes.active="{Binding Is24hActive}"
                  Command="{Binding Load24hCommand}"
                  Padding="12,6" CornerRadius="8"
                  ToolTip.Tip="Last 24 hours (1-min rollups)">
            <TextBlock Text="24h" FontSize="{DynamicResource NxFont12}"/>
          </Button>
          <Button Classes="nx-btn-ghost" Classes.active="{Binding Is7dActive}"
                  Command="{Binding Load7dCommand}"
                  Padding="12,6" CornerRadius="8"
                  ToolTip.Tip="Last 7 days (5-min rollups)">
            <TextBlock Text="7d" FontSize="{DynamicResource NxFont12}"/>
          </Button>
          <Button Classes="nx-btn-ghost" Classes.active="{Binding Is30dActive}"
                  Command="{Binding Load30dCommand}"
                  Padding="12,6" CornerRadius="8"
                  ToolTip.Tip="Last 30 days (1-hour rollups)">
            <TextBlock Text="30d" FontSize="{DynamicResource NxFont12}"/>
          </Button>

          <Border Width="1" Background="{StaticResource GlassBorderBrush}"
                  Margin="6,0" VerticalAlignment="Stretch"/>

          <!-- Refresh -->
          <Button Classes="nx-btn-ghost"
                  Command="{Binding RefreshCommand}"
                  Padding="10,6" CornerRadius="8"
                  ToolTip.Tip="Refresh">
            <TextBlock Text="↺" FontSize="{DynamicResource NxFont13}"/>
          </Button>
        </StackPanel>

        <!-- Right: status + DB size -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
          <!-- Loading indicator -->
          <TextBlock Text="Loading…"
                     FontSize="{DynamicResource NxFont11}"
                     Foreground="{DynamicResource AccentBlueBrush}"
                     IsVisible="{Binding IsLoading}"
                     VerticalAlignment="Center"/>
          <!-- DB size -->
          <TextBlock Text="{Binding DbInfoText}"
                     FontSize="{DynamicResource NxFont11}"
                     Foreground="{StaticResource TextTertiaryBrush}"
                     IsVisible="{Binding DbInfoText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                     VerticalAlignment="Center"/>
        </StackPanel>

      </Grid>
    </Border>

    <!-- ===== CONTENT ===== -->
    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel Margin="16,12" Spacing="10">

        <!-- Status text -->
        <TextBlock Text="{Binding StatusText}"
                   FontSize="{DynamicResource NxFont12}"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,0,0,4"
                   TextWrapping="Wrap"/>

        <!-- ── CPU ── -->
        <Border Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="{StaticResource CornerLG}"
                BorderBrush="{StaticResource GlassBorderBrush}"
                BorderThickness="1"
                Padding="16,12">
          <Grid RowDefinitions="Auto,*">
            <TextBlock Text="CPU Usage"
                       FontSize="{DynamicResource NxFont13}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,8"/>
            <lvc:CartesianChart Grid.Row="1"
                                Series="{Binding CpuSeries}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding CpuYAxes}"
                                Height="130"
                                Background="Transparent"
                                AnimationsSpeed="0:0:0.15"/>
          </Grid>
        </Border>

        <!-- ── Memory ── -->
        <Border Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="{StaticResource CornerLG}"
                BorderBrush="{StaticResource GlassBorderBrush}"
                BorderThickness="1"
                Padding="16,12">
          <Grid RowDefinitions="Auto,*">
            <TextBlock Text="Memory Used (GB)"
                       FontSize="{DynamicResource NxFont13}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,8"/>
            <lvc:CartesianChart Grid.Row="1"
                                Series="{Binding MemSeries}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding MemYAxes}"
                                Height="130"
                                Background="Transparent"
                                AnimationsSpeed="0:0:0.15"/>
          </Grid>
        </Border>

        <!-- ── Disk I/O ── -->
        <Border Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="{StaticResource CornerLG}"
                BorderBrush="{StaticResource GlassBorderBrush}"
                BorderThickness="1"
                Padding="16,12">
          <Grid RowDefinitions="Auto,Auto,*">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="Disk I/O (MB/s)"
                         FontSize="{DynamicResource NxFont13}"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextPrimaryBrush}"/>
              <!-- Legend -->
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                  <Border Width="10" Height="3" Background="#FFFF9F0A" CornerRadius="2"/>
                  <TextBlock Text="Read" FontSize="{DynamicResource NxFont11}"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                  <Border Width="10" Height="3" Background="#FFFF453A" CornerRadius="2"/>
                  <TextBlock Text="Write" FontSize="{DynamicResource NxFont11}"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
              </StackPanel>
            </Grid>
            <lvc:CartesianChart Grid.Row="1"
                                Series="{Binding DiskSeries}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding DiskYAxes}"
                                Height="130"
                                Margin="0,8,0,0"
                                Background="Transparent"
                                AnimationsSpeed="0:0:0.15"/>
          </Grid>
        </Border>

        <!-- ── Network ── -->
        <Border Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="{StaticResource CornerLG}"
                BorderBrush="{StaticResource GlassBorderBrush}"
                BorderThickness="1"
                Padding="16,12">
          <Grid RowDefinitions="Auto,Auto,*">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="Network (MB/s)"
                         FontSize="{DynamicResource NxFont13}"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextPrimaryBrush}"/>
              <!-- Legend -->
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                  <Border Width="10" Height="3" Background="#FF64D2FF" CornerRadius="2"/>
                  <TextBlock Text="Send" FontSize="{DynamicResource NxFont11}"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                  <Border Width="10" Height="3" Background="#FFBF5AF2" CornerRadius="2"/>
                  <TextBlock Text="Recv" FontSize="{DynamicResource NxFont11}"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
              </StackPanel>
            </Grid>
            <lvc:CartesianChart Grid.Row="1"
                                Series="{Binding NetSeries}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding NetYAxes}"
                                Height="130"
                                Margin="0,8,0,0"
                                Background="Transparent"
                                AnimationsSpeed="0:0:0.15"/>
          </Grid>
        </Border>

        <!-- ── GPU ── -->
        <Border Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="{StaticResource CornerLG}"
                BorderBrush="{StaticResource GlassBorderBrush}"
                BorderThickness="1"
                Padding="16,12">
          <Grid RowDefinitions="Auto,*">
            <TextBlock Text="GPU Usage"
                       FontSize="{DynamicResource NxFont13}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,8"/>
            <lvc:CartesianChart Grid.Row="1"
                                Series="{Binding GpuSeries}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding GpuYAxes}"
                                Height="130"
                                Background="Transparent"
                                AnimationsSpeed="0:0:0.15"/>
          </Grid>
        </Border>

        <!-- ── Top Processes ── -->
        <Border Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="{StaticResource CornerLG}"
                BorderBrush="{StaticResource GlassBorderBrush}"
                BorderThickness="1"
                Padding="16,12"
                IsVisible="{Binding HasData}">
          <StackPanel Spacing="8">
            <TextBlock Text="Top Processes (by avg CPU)"
                       FontSize="{DynamicResource NxFont13}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>

            <!-- Column headers -->
            <Grid ColumnDefinitions="*,80,80,90" Margin="0,4,0,0">
              <TextBlock Grid.Column="0" Text="Process"
                         FontSize="{DynamicResource NxFont11}"
                         Foreground="{StaticResource TextTertiaryBrush}"
                         FontWeight="SemiBold"/>
              <TextBlock Grid.Column="1" Text="Avg CPU"
                         FontSize="{DynamicResource NxFont11}"
                         Foreground="{StaticResource TextTertiaryBrush}"
                         FontWeight="SemiBold"
                         TextAlignment="Right"/>
              <TextBlock Grid.Column="2" Text="Peak CPU"
                         FontSize="{DynamicResource NxFont11}"
                         Foreground="{StaticResource TextTertiaryBrush}"
                         FontWeight="SemiBold"
                         TextAlignment="Right"/>
              <TextBlock Grid.Column="3" Text="Avg Mem"
                         FontSize="{DynamicResource NxFont11}"
                         Foreground="{StaticResource TextTertiaryBrush}"
                         FontWeight="SemiBold"
                         TextAlignment="Right"/>
            </Grid>

            <Border Height="1" Background="{StaticResource GlassBorderBrush}"/>

            <!-- Process rows -->
            <ItemsControl ItemsSource="{Binding TopProcesses}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="*,80,80,90" Margin="0,3">
                    <TextBlock Grid.Column="0"
                               Text="{Binding Name}"
                               FontSize="{DynamicResource NxFont12}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding AvgCpuPercent, StringFormat='{}{0:F1}%'}"
                               FontSize="{DynamicResource NxFont12}"
                               Foreground="{DynamicResource AccentBlueBrush}"
                               TextAlignment="Right"
                               FontFamily="{StaticResource FontMono}"/>
                    <TextBlock Grid.Column="2"
                               Text="{Binding PeakCpuPercent, StringFormat='{}{0:F1}%'}"
                               FontSize="{DynamicResource NxFont12}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextAlignment="Right"
                               FontFamily="{StaticResource FontMono}"/>
                    <TextBlock Grid.Column="3"
                               Text="{Binding AvgMemMb, StringFormat='{}{0:F0} MB'}"
                               FontSize="{DynamicResource NxFont12}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextAlignment="Right"
                               FontFamily="{StaticResource FontMono}"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </StackPanel>
        </Border>

        <!-- Bottom spacer -->
        <Border Height="16"/>

      </StackPanel>
    </ScrollViewer>

  </Grid>
</UserControl>
