<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             xmlns:models="using:NexusMonitor.Core.Models"
             x:Class="NexusMonitor.UI.Views.PerformanceProfilesView"
             x:DataType="vm:PerformanceProfilesViewModel"
             x:CompileBindings="False">

  <DockPanel>

    <!-- ══ Header ══════════════════════════════════════════════════════════ -->
    <Border DockPanel.Dock="Top"
            Padding="16,10"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <DockPanel>
        <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
          <TextBlock Text="Performance Profiles"
                     FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock FontSize="{DynamicResource NxFont10}"
                     Foreground="{DynamicResource TextTertiaryBrush}">
            <Run Text="Active: "/>
            <Run Text="{Binding ActiveProfileName}"
                 Foreground="{DynamicResource AccentBrush}"
                 FontWeight="Medium"/>
          </TextBlock>
        </StackPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6"
                    VerticalAlignment="Center">
          <Button Classes="nx-btn"
                  Command="{Binding CreateProfileCommand}"
                  ToolTip.Tip="Create a new performance profile">
            <TextBlock Text="＋ New Profile" FontSize="{DynamicResource NxFont12}"/>
          </Button>
          <Button Classes="nx-btn"
                  Command="{Binding EditProfileCommand}"
                  IsEnabled="{Binding SelectedProfile, Converter={x:Static ObjectConverters.IsNotNull}}"
                  IsVisible="{Binding !IsEditing}"
                  ToolTip.Tip="Edit the selected profile">
            <TextBlock Text="✏ Edit" FontSize="{DynamicResource NxFont12}"/>
          </Button>
          <Button Classes="nx-btn-danger"
                  Command="{Binding DeleteProfileCommand}"
                  IsEnabled="{Binding SelectedProfile, Converter={x:Static ObjectConverters.IsNotNull}}"
                  ToolTip.Tip="Delete the selected profile">
            <TextBlock Text="🗑 Delete" FontSize="{DynamicResource NxFont12}"/>
          </Button>
        </StackPanel>
        <Panel/>
      </DockPanel>
    </Border>

    <!-- ══ Body: two-column layout ════════════════════════════════════════ -->
    <Grid ColumnDefinitions="280,Auto,*">

      <!-- ── Left: Profile list ─────────────────────────────────────────── -->
      <Border Grid.Column="0"
              BorderBrush="{DynamicResource BorderSubtleBrush}"
              BorderThickness="0,0,1,0">
        <DockPanel>

          <!-- Status text -->
          <TextBlock DockPanel.Dock="Bottom"
                     Text="{Binding StatusText}"
                     FontSize="{DynamicResource NxFont10}"
                     Foreground="{DynamicResource AccentBrush}"
                     Margin="12,6"
                     IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

          <ListBox ItemsSource="{Binding Profiles}"
                   SelectedItem="{Binding SelectedProfile}"
                   Background="Transparent"
                   Padding="8">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:PerformanceProfile">
                <Border Padding="8,6" CornerRadius="{StaticResource CornerSM}">
                  <DockPanel>
                    <!-- Activate / Deactivate toggle -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4"
                                VerticalAlignment="Center">
                    </StackPanel>

                    <StackPanel>
                      <TextBlock Text="{Binding Name}"
                                 FontSize="{DynamicResource NxFont13}"
                                 FontWeight="Medium"
                                 Foreground="{DynamicResource TextPrimaryBrush}"/>
                      <TextBlock Text="{Binding Description}"
                                 FontSize="{DynamicResource NxFont10}"
                                 Foreground="{DynamicResource TextTertiaryBrush}"
                                 IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>
                  </DockPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

        </DockPanel>
      </Border>

      <!-- ── Splitter ───────────────────────────────────────────────────── -->
      <GridSplitter Grid.Column="1"
                    Width="4"
                    Background="Transparent"
                    ResizeDirection="Columns"/>

      <!-- ── Right: detail / editor ─────────────────────────────────────── -->
      <ScrollViewer Grid.Column="2"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Spacing="16">

          <!-- No-selection placeholder -->
          <TextBlock Text="Select a profile to view details, or create a new one."
                     FontSize="{DynamicResource NxFont12}"
                     Foreground="{DynamicResource TextTertiaryBrush}"
                     IsVisible="{Binding SelectedProfile, Converter={x:Static ObjectConverters.IsNull}}"/>

          <!-- ── Profile detail / edit ──────────────────────────────────── -->
          <StackPanel Spacing="12"
                      IsVisible="{Binding SelectedProfile, Converter={x:Static ObjectConverters.IsNotNull}}">

            <!-- Activate / Deactivate button -->
            <StackPanel Orientation="Horizontal" Spacing="8"
                        IsVisible="{Binding !IsEditing}">
              <Button Classes="nx-btn"
                      Command="{Binding ActivateProfileCommand}"
                      IsEnabled="{Binding !IsSelectedProfileActive}"
                      ToolTip.Tip="Activate this profile — applies process rules and optionally switches power plan">
                <TextBlock Text="▶ Activate" FontSize="{DynamicResource NxFont12}"/>
              </Button>
              <Button Classes="nx-btn"
                      Command="{Binding DeactivateProfileCommand}"
                      IsEnabled="{Binding IsSelectedProfileActive}"
                      ToolTip.Tip="Deactivate profile and restore original process priorities">
                <TextBlock Text="⏹ Deactivate" FontSize="{DynamicResource NxFont12}"/>
              </Button>
            </StackPanel>

            <!-- Read-only view (not editing) -->
            <Border IsVisible="{Binding !IsEditing}"
                    Padding="16"
                    Background="{DynamicResource BgElevatedBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerLG}">
              <StackPanel Spacing="8">
                <TextBlock Text="{Binding SelectedProfile.Name}"
                           FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding SelectedProfile.Description}"
                           FontSize="{DynamicResource NxFont11}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           IsVisible="{Binding SelectedProfile.Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <Separator/>
                <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Power Plan:"
                             FontSize="{DynamicResource NxFont11}"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                  <TextBlock Grid.Row="0" Grid.Column="1"
                             Text="{Binding SelectedProfile.PowerPlanName}"
                             FontSize="{DynamicResource NxFont11}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             IsVisible="{Binding SelectedProfile.ChangePowerPlan}"/>
                  <TextBlock Grid.Row="0" Grid.Column="1" Text="(no change)"
                             FontSize="{DynamicResource NxFont11}"
                             Foreground="{DynamicResource TextTertiaryBrush}"
                             IsVisible="{Binding !SelectedProfile.ChangePowerPlan}"/>

                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Process Rules:"
                             FontSize="{DynamicResource NxFont11}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             Margin="0,4,0,0"/>
                  <TextBlock Grid.Row="1" Grid.Column="1"
                             Text="{Binding SelectedProfile.ProcessRules.Count, StringFormat='{}{0} rule(s)'}"
                             FontSize="{DynamicResource NxFont11}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             Margin="0,4,0,0"/>
                </Grid>
              </StackPanel>
            </Border>

            <!-- Edit form -->
            <Border IsVisible="{Binding IsEditing}"
                    Padding="16"
                    Background="{DynamicResource BgElevatedBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerLG}">
              <StackPanel Spacing="12">

                <TextBlock Text="Edit Profile"
                           FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <Separator/>

                <!-- Name -->
                <Grid ColumnDefinitions="120,*">
                  <TextBlock Text="Name" VerticalAlignment="Center"
                             FontSize="{DynamicResource NxFont12}"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                  <TextBox Grid.Column="1" Classes="nx-input"
                           Text="{Binding EditName}"
                           Watermark="Profile name"/>
                </Grid>

                <!-- Description -->
                <Grid ColumnDefinitions="120,*">
                  <TextBlock Text="Description" VerticalAlignment="Center"
                             FontSize="{DynamicResource NxFont12}"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                  <TextBox Grid.Column="1" Classes="nx-input"
                           Text="{Binding EditDescription}"
                           Watermark="Optional description"/>
                </Grid>

                <!-- Power Plan -->
                <Grid ColumnDefinitions="120,Auto,*" RowDefinitions="Auto">
                  <TextBlock Text="Power Plan" VerticalAlignment="Center"
                             FontSize="{DynamicResource NxFont12}"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                  <CheckBox Grid.Column="1" Margin="0,0,8,0"
                            IsChecked="{Binding EditChangePowerPlan}"
                            ToolTip.Tip="Switch power plan when profile is activated"/>
                  <ComboBox Grid.Column="2"
                            ItemsSource="{Binding AvailablePowerPlans}"
                            SelectedItem="{Binding EditPowerPlanName}"
                            IsEnabled="{Binding EditChangePowerPlan}"
                            FontSize="{DynamicResource NxFont12}"/>
                </Grid>

                <!-- Process Rules -->
                <TextBlock Text="Process Rules"
                           FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,8,0,0"/>
                <TextBlock Text="Rules are applied when the profile is activated. Priorities are restored to Normal on deactivate."
                           FontSize="{DynamicResource NxFont10}"
                           Foreground="{DynamicResource TextTertiaryBrush}"/>

                <DataGrid ItemsSource="{Binding EditRules}"
                          AutoGenerateColumns="False"
                          CanUserSortColumns="False"
                          GridLinesVisibility="Horizontal"
                          MinHeight="120"
                          MaxHeight="300"
                          Background="Transparent"
                          BorderThickness="1"
                          BorderBrush="{DynamicResource BorderSubtleBrush}">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Process (wildcard)"
                                        Binding="{Binding ProcessNamePattern}"
                                        Width="*"/>
                    <DataGridTemplateColumn Header="Priority" Width="130">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:ProfileProcessRule">
                          <ComboBox SelectedItem="{Binding PriorityLabel}"
                                    ItemsSource="{x:Static vm:PerformanceProfilesViewModel.PriorityOptions}"
                                    FontSize="{DynamicResource NxFont11}"
                                    Padding="4,2"
                                    Background="Transparent"
                                    BorderThickness="0"/>
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Efficiency Mode" Width="120">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:ProfileProcessRule">
                          <CheckBox IsChecked="{Binding EfficiencyMode}"
                                    HorizontalAlignment="Center"/>
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Width="36">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:ProfileProcessRule">
                          <Button Classes="nx-btn-icon"
                                  Command="{Binding $parent[UserControl].DataContext.RemoveProcessRuleCommand}"
                                  CommandParameter="{Binding}"
                                  ToolTip.Tip="Remove rule">
                            <TextBlock Text="✕" Foreground="{DynamicResource ColorDangerBrush}"
                                       FontSize="{DynamicResource NxFont11}"/>
                          </Button>
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                  </DataGrid.Columns>
                </DataGrid>

                <Button Classes="nx-btn"
                        Command="{Binding AddProcessRuleCommand}"
                        HorizontalAlignment="Left">
                  <TextBlock Text="＋ Add Rule" FontSize="{DynamicResource NxFont11}"/>
                </Button>

                <!-- Save / Cancel -->
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                  <Button Classes="nx-btn-primary"
                          Command="{Binding SaveProfileCommand}">
                    <TextBlock Text="Save Profile" FontSize="{DynamicResource NxFont12}"/>
                  </Button>
                  <Button Classes="nx-btn"
                          Command="{Binding CancelEditCommand}">
                    <TextBlock Text="Cancel" FontSize="{DynamicResource NxFont12}"/>
                  </Button>
                </StackPanel>

              </StackPanel>
            </Border>

          </StackPanel>
        </StackPanel>
      </ScrollViewer>

    </Grid>
  </DockPanel>
</UserControl>
