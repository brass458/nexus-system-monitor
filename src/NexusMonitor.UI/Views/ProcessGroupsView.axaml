<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             xmlns:conv="using:NexusMonitor.UI.Converters"
             x:Class="NexusMonitor.UI.Views.ProcessGroupsView"
             x:DataType="vm:ProcessGroupsViewModel"
             x:CompileBindings="False">

  <UserControl.Resources>
    <conv:HexColorToBrushConverter x:Key="HexBrush" />
  </UserControl.Resources>

  <Grid ColumnDefinitions="220,*">

    <!-- ── LEFT PANEL: group list ── -->
    <Border Grid.Column="0"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,1,0">
    <Grid RowDefinitions="Auto,*,Auto">

      <!-- Header -->
      <Border Grid.Row="0"
              Padding="12,10"
              BorderBrush="{DynamicResource BorderSubtleBrush}"
              BorderThickness="0,0,0,1">
        <TextBlock Text="Process Groups"
                   FontSize="{DynamicResource NxFont13}"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
      </Border>

      <!-- List -->
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Groups}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ProcessGroupsViewModel">
              <Border Padding="8,6"
                      BorderBrush="{DynamicResource BorderSubtleBrush}"
                      BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto">

                  <!-- Color badge -->
                  <Border Grid.Column="0"
                          Width="10" Height="10"
                          CornerRadius="2"
                          Margin="0,0,8,0"
                          VerticalAlignment="Center"
                          Background="{Binding Color, Converter={StaticResource HexBrush}}"/>

                  <!-- Name + pattern count -->
                  <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}"
                               FontSize="{DynamicResource NxFont12}"
                               FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock FontSize="{DynamicResource NxFont10}"
                               Foreground="{DynamicResource TextTertiaryBrush}">
                      <Run Text="{Binding Patterns.Count}"/>
                      <Run Text="pattern(s)"/>
                    </TextBlock>
                  </StackPanel>

                  <!-- Edit button -->
                  <Button Grid.Column="2"
                          Classes="nx-btn"
                          Padding="4,2"
                          Margin="4,0,2,0"
                          Command="{Binding DataContext.EditGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}"
                          ToolTip.Tip="Edit group">
                    <TextBlock Text="✎" FontSize="{DynamicResource NxFont11}"/>
                  </Button>

                  <!-- Delete button -->
                  <Button Grid.Column="3"
                          Classes="nx-btn"
                          Padding="4,2"
                          Command="{Binding DataContext.DeleteGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}"
                          ToolTip.Tip="Delete group">
                    <TextBlock Text="✕"
                               FontSize="{DynamicResource NxFont11}"
                               Foreground="{StaticResource ColorDangerBrush}"/>
                  </Button>

                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- New Group button -->
      <Button Grid.Row="2"
              Classes="nx-btn"
              Margin="8"
              HorizontalAlignment="Stretch"
              Command="{Binding NewGroupCommand}"
              ToolTip.Tip="Create a new process group">
        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
          <TextBlock Text="+" FontSize="{DynamicResource NxFont13}" FontWeight="Bold"/>
          <TextBlock Text="New Group" FontSize="{DynamicResource NxFont12}"/>
        </StackPanel>
      </Button>

    </Grid>
    </Border>

    <!-- ── RIGHT PANEL: editor (visible when IsEditorVisible) ── -->
    <Border Grid.Column="1"
            IsVisible="{Binding IsEditorVisible}"
            Background="{DynamicResource BgPrimaryBrush}"
            Padding="16,14">

      <StackPanel Spacing="12" MaxWidth="360">

        <!-- Editor title -->
        <TextBlock Text="{Binding EditId, StringFormat='Edit Group'}"
                   FontSize="{DynamicResource NxFont13}"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>

        <!-- Name field -->
        <StackPanel Spacing="4">
          <TextBlock Text="Name"
                     FontSize="{DynamicResource NxFont11}"
                     Foreground="{DynamicResource TextSecondaryBrush}"/>
          <TextBox Classes="nx-input"
                   Text="{Binding EditName}"
                   Watermark="e.g. Browsers"/>
        </StackPanel>

        <!-- Color field -->
        <StackPanel Spacing="4">
          <TextBlock Text="Color (hex)"
                     FontSize="{DynamicResource NxFont11}"
                     Foreground="{DynamicResource TextSecondaryBrush}"/>
          <Grid ColumnDefinitions="*,Auto">
            <TextBox Grid.Column="0"
                     Classes="nx-input"
                     Text="{Binding EditColor}"
                     Watermark="#5B9BD5"/>
            <Border Grid.Column="1"
                    Width="28" Height="28"
                    CornerRadius="4"
                    Margin="6,0,0,0"
                    VerticalAlignment="Center"
                    Background="{Binding EditColor, Converter={StaticResource HexBrush}}"/>
          </Grid>
        </StackPanel>

        <!-- Patterns field -->
        <StackPanel Spacing="4">
          <TextBlock Text="Patterns (one per line, wildcards supported)"
                     FontSize="{DynamicResource NxFont11}"
                     Foreground="{DynamicResource TextSecondaryBrush}"/>
          <TextBox Classes="nx-input"
                   Text="{Binding EditPatterns}"
                   AcceptsReturn="True"
                   Height="100"
                   Watermark="chrome*&#10;firefox*&#10;msedge*"
                   TextWrapping="Wrap"
                   VerticalContentAlignment="Top"/>
        </StackPanel>

        <!-- Validation error -->
        <TextBlock Text="{Binding ValidationMessage}"
                   IsVisible="{Binding HasValidationError}"
                   FontSize="{DynamicResource NxFont11}"
                   Foreground="{StaticResource ColorDangerBrush}"/>

        <!-- Save / Cancel -->
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Classes="nx-btn-primary"
                  Command="{Binding SaveGroupCommand}"
                  Width="80">
            <TextBlock Text="Save" FontSize="{DynamicResource NxFont12}"/>
          </Button>
          <Button Classes="nx-btn"
                  Command="{Binding CancelEditCommand}"
                  Width="80">
            <TextBlock Text="Cancel" FontSize="{DynamicResource NxFont12}"/>
          </Button>
        </StackPanel>

      </StackPanel>
    </Border>

    <!-- Empty state when editor is hidden -->
    <Border Grid.Column="1"
            IsVisible="{Binding !IsEditorVisible}"
            Background="{DynamicResource BgPrimaryBrush}">
      <TextBlock Text="Select a group to edit, or click New Group."
                 FontSize="{DynamicResource NxFont12}"
                 Foreground="{DynamicResource TextTertiaryBrush}"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"/>
    </Border>

  </Grid>
</UserControl>
