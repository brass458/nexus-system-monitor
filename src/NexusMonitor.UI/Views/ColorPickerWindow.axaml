<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexusMonitor.UI.ViewModels"
        xmlns:controls="using:NexusMonitor.UI.Controls"
        x:Class="NexusMonitor.UI.Views.ColorPickerWindow"
        x:DataType="vm:SettingsViewModel"
        x:CompileBindings="False"
        Title="Pick Color"
        Width="252" Height="336"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="None"
        Background="Transparent"
        WindowStartupLocation="CenterOwner">

  <!-- TransparencyLevelHint set in code-behind -->

  <Border Background="{DynamicResource BgElevatedBrush}"
          BorderBrush="{DynamicResource GlassBorderBrush}"
          BorderThickness="1"
          CornerRadius="12"
          BoxShadow="0 8 32 0 #60000000"
          Padding="16">
    <StackPanel Spacing="12">

      <!-- ── Title bar (drag handle) ── -->
      <DockPanel PointerPressed="OnDragPressed">
        <Button DockPanel.Dock="Right"
                Classes="nx-btn-ghost"
                Padding="5,3"
                Click="OnCancel"
                ToolTip.Tip="Cancel — restore original color">
          <TextBlock Text="✕" FontSize="11"
                     Foreground="{StaticResource TextSecondaryBrush}"/>
        </Button>
        <TextBlock Text="Custom Accent Color"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   VerticalAlignment="Center"/>
      </DockPanel>

      <!-- ── Color wheel ── -->
      <controls:ColorWheelControl Width="196" Height="228"
                                  HorizontalAlignment="Center"
                                  SelectedColor="{Binding PickerAccentColor}"/>

      <!-- ── Hex readout ── -->
      <Border Background="{DynamicResource BgSecondaryBrush}"
              CornerRadius="8" Padding="12,6">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <TextBlock Grid.Column="0"
                     Text="HEX"
                     FontSize="11" FontWeight="Medium" LetterSpacing="0.6"
                     Foreground="{StaticResource TextTertiaryBrush}"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0"/>
          <TextBlock Grid.Column="1"
                     Text="{Binding AccentColorHex}"
                     FontSize="12" FontWeight="Medium"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     VerticalAlignment="Center"/>
          <Border Grid.Column="2"
                  Width="18" Height="18" CornerRadius="9"
                  Background="{DynamicResource AccentBlueBrush}"
                  VerticalAlignment="Center"/>
        </Grid>
      </Border>

      <!-- ── Apply / Cancel ── -->
      <Grid ColumnDefinitions="*,8,*">
        <Button Grid.Column="0"
                Classes="nx-btn"
                Content="Cancel"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Click="OnCancel"/>
        <Button Grid.Column="2"
                Classes="nx-btn-accent"
                Content="Apply"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Click="OnApply"/>
      </Grid>

    </StackPanel>
  </Border>

</Window>
