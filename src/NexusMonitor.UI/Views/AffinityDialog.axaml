<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NexusMonitor.UI.Views.AffinityDialog"
        x:CompileBindings="False"
        Title="Set CPU Affinity"
        Width="340" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SystemDecorations="BorderOnly"
        Background="{DynamicResource BgBaseBrush}">

  <Border Padding="20" Background="{DynamicResource BgPrimaryBrush}" CornerRadius="8">
    <StackPanel Spacing="12">

      <!-- Header -->
      <TextBlock Text="{Binding ProcessName}" FontSize="14" FontWeight="SemiBold"
                 Foreground="{StaticResource TextPrimaryBrush}"/>
      <TextBlock Text="Select which CPUs this process is allowed to use:"
                 FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                 TextWrapping="Wrap"/>

      <!-- Select All / None -->
      <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
        <Button Classes="nx-btn" Content="Select All" Click="OnSelectAll"/>
        <Button Classes="nx-btn" Content="Select None" Click="OnSelectNone"/>
      </StackPanel>

      <!-- CPU checkboxes grid -->
      <ItemsControl ItemsSource="{Binding Cpus}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel Orientation="Horizontal"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <CheckBox IsChecked="{Binding IsSelected}"
                      Content="{Binding Label}"
                      Margin="0,2,12,2"
                      MinWidth="70"
                      FontSize="12"
                      Foreground="{StaticResource TextPrimaryBrush}"/>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Buttons -->
      <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
        <Button Classes="nx-btn" Content="OK" Width="80" Click="OnOk"/>
        <Button Classes="nx-btn" Content="Cancel" Width="80" Click="OnCancel"/>
      </StackPanel>

    </StackPanel>
  </Border>
</Window>
