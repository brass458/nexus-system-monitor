<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             xmlns:conv="using:NexusMonitor.UI.Converters"
             xmlns:models="using:NexusMonitor.Core.Models"
             x:Class="NexusMonitor.UI.Views.ServicesView"
             x:DataType="vm:ServicesViewModel"
             x:CompileBindings="False">

  <UserControl.Resources>
    <conv:ServiceStateToColorConverter x:Key="StateColor"/>
    <conv:NullToBoolConverter x:Key="NullToBool"/>
  </UserControl.Resources>

  <DockPanel>

    <!-- Toolbar -->
    <Border DockPanel.Dock="Top"
            Padding="16,10"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left"
                   Text="Services"
                   FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   VerticalAlignment="Center"
                   Margin="0,0,12,0"/>

        <!-- Search box pinned to the right -->
        <TextBox DockPanel.Dock="Right"
                 Name="SearchBox"
                 Classes="nx-input"
                 Text="{Binding SearchText}"
                 Watermark="Search name, display name, path…"
                 Width="260"
                 VerticalAlignment="Center"/>

        <!-- Action buttons -->
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Button Classes="nx-btn"
                  Command="{Binding StartServiceCommand}"
                  IsEnabled="{Binding SelectedService, Converter={StaticResource NullToBool}}">
            <TextBlock Text="&#x25B6;  Start" FontSize="{DynamicResource NxFont11}"/>
          </Button>
          <Button Classes="nx-btn"
                  Command="{Binding StopServiceCommand}"
                  IsEnabled="{Binding SelectedService, Converter={StaticResource NullToBool}}">
            <TextBlock Text="&#x23F9;  Stop" FontSize="{DynamicResource NxFont11}"/>
          </Button>
          <Button Classes="nx-btn"
                  Command="{Binding RestartServiceCommand}"
                  IsEnabled="{Binding SelectedService, Converter={StaticResource NullToBool}}">
            <TextBlock Text="&#x21BA;  Restart" FontSize="{DynamicResource NxFont11}"/>
          </Button>
          <ToggleButton Classes="nx-toggle"
                        IsChecked="{Binding IsDetailPanelVisible}"
                        ToolTip.Tip="Show/hide service details panel">
            <TextBlock Text="Details" FontSize="{DynamicResource NxFont11}"/>
          </ToggleButton>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Status bar -->
    <Border DockPanel.Dock="Bottom"
            Padding="16,6"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="0,1,0,0">
      <DockPanel>

        <!-- Error message (right-aligned, shown only when non-empty) -->
        <TextBlock DockPanel.Dock="Right"
                   Text="{Binding LastError}"
                   IsVisible="{Binding LastError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   FontSize="{DynamicResource NxFont11}"
                   Foreground="{StaticResource ColorDangerBrush}"
                   VerticalAlignment="Center"/>

        <!-- Stats -->
        <StackPanel Orientation="Horizontal" Spacing="24">
          <TextBlock FontSize="{DynamicResource NxFont11}" Foreground="{StaticResource TextSecondaryBrush}">
            <Run Text="Total: "/>
            <Run Text="{Binding TotalCount}"   Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"/>
          </TextBlock>
          <TextBlock FontSize="{DynamicResource NxFont11}" Foreground="{StaticResource TextSecondaryBrush}">
            <Run Text="Running: "/>
            <Run Text="{Binding RunningCount}" Foreground="{StaticResource ColorSuccessBrush}" FontWeight="Medium"/>
          </TextBlock>
        </StackPanel>

      </DockPanel>
    </Border>

    <!-- Table + sidebar -->
    <Grid ColumnDefinitions="*,Auto,Auto">

      <!-- DataGrid + loading overlay -->
      <Panel Grid.Column="0">
        <DataGrid Classes="nx-grid"
                  ItemsSource="{Binding Services}"
                  SelectedItem="{Binding SelectedService}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  CanUserReorderColumns="True"
                  IsReadOnly="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
          <DataGrid.ContextMenu>
            <ContextMenu>
              <MenuItem Header="Start"   Command="{Binding StartServiceCommand}"/>
              <MenuItem Header="Stop"    Command="{Binding StopServiceCommand}"/>
              <MenuItem Header="Restart" Command="{Binding RestartServiceCommand}"/>
              <Separator/>
              <MenuItem Header="Go to Process"      Command="{Binding GoToProcessCommand}"/>
              <MenuItem Header="Open File Location" Command="{Binding OpenFileLocationCommand}"/>
            </ContextMenu>
          </DataGrid.ContextMenu>
          <DataGrid.Columns>
            <DataGridTemplateColumn Header="Status" Width="1*" MinWidth="120" SortMemberPath="State">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="models:ServiceInfo">
                  <Border CornerRadius="4" Padding="5,2" Margin="4,2"
                          HorizontalAlignment="Left"
                          Background="{Binding State, Converter={StaticResource StateColor}}">
                    <TextBlock Text="{Binding State}" FontSize="{DynamicResource NxFont10}" Foreground="White"/>
                  </Border>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="Name"         Binding="{Binding Name}"        Width="1.5*" MinWidth="90"  IsReadOnly="True"/>
            <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="2.5*" MinWidth="145" IsReadOnly="True"/>
            <DataGridTextColumn Header="Start Type"   Binding="{Binding StartType}"   Width="1.3*" MinWidth="120" IsReadOnly="True"/>
            <DataGridTextColumn Header="PID"          Binding="{Binding ProcessId}"   Width="0.7*" MinWidth="65"  IsReadOnly="True"/>
            <DataGridTextColumn Header="Account"      Binding="{Binding UserAccount}" Width="1.3*" MinWidth="90"  IsReadOnly="True"/>
            <DataGridTextColumn Header="Binary Path"  Binding="{Binding BinaryPath}"  Width="3*"   MinWidth="120" IsReadOnly="True"/>
          </DataGrid.Columns>
        </DataGrid>

        <!-- Loading overlay -->
        <Border IsVisible="{Binding IsLoading}"
                Background="#80000000">
          <TextBlock Text="Loading services&#x2026;"
                     FontSize="{DynamicResource NxFont14}"
                     Foreground="White"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>
      </Panel>

      <!-- Splitter -->
      <GridSplitter Grid.Column="1"
                    Width="1"
                    Background="{StaticResource BorderSubtleBrush}"
                    IsVisible="{Binding IsServiceDetailShown}"/>

      <!-- Detail sidebar -->
      <Border Grid.Column="2"
              Width="280"
              Background="{DynamicResource BgSecondaryBrush}"
              IsVisible="{Binding IsServiceDetailShown}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="0"
                      DataContext="{Binding SelectedService}"
                      Margin="14,12">

            <!-- Header: service name -->
            <TextBlock Text="{Binding DisplayName}"
                       FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,2"/>
            <TextBlock Text="{Binding Name}"
                       FontSize="{DynamicResource NxFont11}"
                       Foreground="{StaticResource TextTertiaryBrush}"
                       Margin="0,0,0,10"/>

            <Separator Background="{StaticResource BorderSubtleBrush}" Margin="0,0,0,10"/>

            <!-- State badge -->
            <Border CornerRadius="4" Padding="8,3" Margin="0,0,0,10"
                    HorizontalAlignment="Left"
                    Background="{Binding State, Converter={StaticResource StateColor}}">
              <TextBlock Text="{Binding State}" FontSize="{DynamicResource NxFont11}" Foreground="White" FontWeight="Medium"/>
            </Border>

            <!-- Section: Identity -->
            <TextBlock Text="IDENTITY" FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                       Foreground="{StaticResource TextTertiaryBrush}"
                       LetterSpacing="0.8" Margin="0,0,0,6"/>

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,0,0,12">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Type"       Classes="detail-label"/>
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ServiceType}" Classes="detail-value"/>
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Start Type" Classes="detail-label"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding StartType}"   Classes="detail-value"/>
              <TextBlock Grid.Row="2" Grid.Column="0" Text="Account"    Classes="detail-label"/>
              <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UserAccount}" Classes="detail-value"/>
              <TextBlock Grid.Row="3" Grid.Column="0" Text="PID"        Classes="detail-label"/>
              <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ProcessId}"   Classes="detail-value"/>
            </Grid>

            <!-- Section: Description -->
            <TextBlock Text="DESCRIPTION" FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                       Foreground="{StaticResource TextTertiaryBrush}"
                       LetterSpacing="0.8" Margin="0,0,0,6"/>

            <TextBlock Text="{Binding Description}"
                       FontSize="{DynamicResource NxFont11}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <!-- Section: Binary Path -->
            <TextBlock Text="BINARY PATH" FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                       Foreground="{StaticResource TextTertiaryBrush}"
                       LetterSpacing="0.8" Margin="0,0,0,6"/>

            <TextBlock Text="{Binding BinaryPath}"
                       FontSize="{DynamicResource NxFont10}"
                       Foreground="{StaticResource TextTertiaryBrush}"
                       TextWrapping="Wrap"/>

          </StackPanel>
        </ScrollViewer>
      </Border>

    </Grid>

  </DockPanel>
</UserControl>
