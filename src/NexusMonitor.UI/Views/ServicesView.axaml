<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             xmlns:conv="using:NexusMonitor.UI.Converters"
             xmlns:models="using:NexusMonitor.Core.Models"
             x:Class="NexusMonitor.UI.Views.ServicesView"
             x:DataType="vm:ServicesViewModel"
             x:CompileBindings="False">

  <UserControl.Resources>
    <conv:ServiceStateToColorConverter x:Key="StateColor"/>
    <conv:NullToBoolConverter x:Key="NullToBool"/>
  </UserControl.Resources>

  <DockPanel>

    <!-- Toolbar -->
    <Border DockPanel.Dock="Top"
            Padding="16,10"
            Background="{StaticResource BgSecondaryBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left"
                   Text="Services"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   VerticalAlignment="Center"
                   Margin="0,0,12,0"/>

        <!-- Search box pinned to the right -->
        <TextBox DockPanel.Dock="Right"
                 Classes="nx-input"
                 Text="{Binding SearchText}"
                 Watermark="Search name, display name, path…"
                 Width="260"
                 VerticalAlignment="Center"/>

        <!-- Action buttons -->
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Button Classes="nx-btn"
                  Command="{Binding StartServiceCommand}"
                  IsEnabled="{Binding SelectedService, Converter={StaticResource NullToBool}}">
            <TextBlock Text="▶  Start" FontSize="11"/>
          </Button>
          <Button Classes="nx-btn"
                  Command="{Binding StopServiceCommand}"
                  IsEnabled="{Binding SelectedService, Converter={StaticResource NullToBool}}">
            <TextBlock Text="⏹  Stop" FontSize="11"/>
          </Button>
          <Button Classes="nx-btn"
                  Command="{Binding RestartServiceCommand}"
                  IsEnabled="{Binding SelectedService, Converter={StaticResource NullToBool}}">
            <TextBlock Text="↺  Restart" FontSize="11"/>
          </Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Status bar -->
    <Border DockPanel.Dock="Bottom"
            Padding="16,6"
            Background="{StaticResource BgSecondaryBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="0,1,0,0">
      <DockPanel>

        <!-- Error message (right-aligned, shown only when non-empty) -->
        <TextBlock DockPanel.Dock="Right"
                   Text="{Binding LastError}"
                   IsVisible="{Binding LastError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   FontSize="11"
                   Foreground="{StaticResource ColorDangerBrush}"
                   VerticalAlignment="Center"/>

        <!-- Stats -->
        <StackPanel Orientation="Horizontal" Spacing="24">
          <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
            <Run Text="Total: "/>
            <Run Text="{Binding TotalCount}"   Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"/>
          </TextBlock>
          <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
            <Run Text="Running: "/>
            <Run Text="{Binding RunningCount}" Foreground="{StaticResource ColorSuccessBrush}" FontWeight="Medium"/>
          </TextBlock>
        </StackPanel>

      </DockPanel>
    </Border>

    <!-- Table + loading overlay -->
    <Panel>

      <DataGrid Classes="nx-grid"
                ItemsSource="{Binding Services}"
                SelectedItem="{Binding SelectedService}"
                AutoGenerateColumns="False"
                CanUserSortColumns="True"
                CanUserResizeColumns="True"
                IsReadOnly="True">
        <DataGrid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Start"   Command="{Binding StartServiceCommand}"/>
            <MenuItem Header="Stop"    Command="{Binding StopServiceCommand}"/>
            <MenuItem Header="Restart" Command="{Binding RestartServiceCommand}"/>
            <Separator/>
            <MenuItem Header="Go to Process"      Command="{Binding GoToProcessCommand}"/>
            <MenuItem Header="Open File Location" Command="{Binding OpenFileLocationCommand}"/>
          </ContextMenu>
        </DataGrid.ContextMenu>
        <DataGrid.Columns>
          <DataGridTemplateColumn Header="Status" Width="80" SortMemberPath="State">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="models:ServiceInfo">
                <Border CornerRadius="4" Padding="5,2" Margin="4,2"
                        HorizontalAlignment="Left"
                        Background="{Binding State, Converter={StaticResource StateColor}}">
                  <TextBlock Text="{Binding State}" FontSize="10" Foreground="White"/>
                </Border>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="Name"         Binding="{Binding Name}"        Width="180" IsReadOnly="True"/>
          <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="240" IsReadOnly="True"/>
          <DataGridTextColumn Header="Start Type"   Binding="{Binding StartType}"   Width="140" IsReadOnly="True"/>
          <DataGridTextColumn Header="PID"          Binding="{Binding ProcessId}"   Width="70"  IsReadOnly="True"/>
          <DataGridTextColumn Header="Account"      Binding="{Binding UserAccount}" Width="140" IsReadOnly="True"/>
          <DataGridTextColumn Header="Binary Path"  Binding="{Binding BinaryPath}"  Width="*"   IsReadOnly="True"/>
        </DataGrid.Columns>
      </DataGrid>

      <!-- Loading overlay -->
      <Border IsVisible="{Binding IsLoading}"
              Background="#80000000">
        <TextBlock Text="Loading services…"
                   FontSize="14"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
      </Border>

    </Panel>

  </DockPanel>
</UserControl>
