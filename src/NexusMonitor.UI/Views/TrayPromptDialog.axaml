<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NexusMonitor.UI.Views.TrayPromptDialog"
        Title="Nexus Monitor"
        Width="400"
        SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBaseBrush}">

  <Border Padding="28,24"
          Background="{DynamicResource BgPrimaryBrush}"
          BorderBrush="{DynamicResource GlassBorderBrush}"
          BorderThickness="1">
    <StackPanel Spacing="16">

      <!-- Icon + heading row -->
      <StackPanel Orientation="Horizontal" Spacing="14">
        <Border Width="44" Height="44" CornerRadius="11"
                Background="{DynamicResource AccentBlueBrush}">
          <TextBlock Text="N" FontSize="24" FontWeight="Bold"
                     Foreground="White"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>
        <StackPanel VerticalAlignment="Center" Spacing="3">
          <TextBlock Text="What should happen when you close?"
                     FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock Text="You can change this later in Settings → System Tray"
                     FontSize="11"
                     Foreground="{DynamicResource TextTertiaryBrush}"/>
        </StackPanel>
      </StackPanel>

      <Separator Margin="0,2"/>

      <!-- Option buttons (large) -->
      <Grid ColumnDefinitions="*,12,*">

        <!-- Minimize to Tray -->
        <Button Grid.Column="0" Name="TrayBtn"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14,12"
                Cursor="Hand"
                Click="OnMinimizeToTray">
          <StackPanel Spacing="4">
            <TextBlock Text="📌  Minimize to Tray" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="App keeps running in the background. Click the tray icon to restore."
                       FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}"
                       TextWrapping="Wrap"/>
          </StackPanel>
        </Button>

        <!-- Close Application -->
        <Button Grid.Column="2" Name="ExitBtn"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Background="{DynamicResource AccentBlueBrush}"
                BorderThickness="0"
                CornerRadius="10"
                Padding="14,12"
                Cursor="Hand"
                Click="OnCloseApp">
          <StackPanel Spacing="4">
            <TextBlock Text="✕  Close Application" FontSize="13" FontWeight="SemiBold"
                       Foreground="White"/>
            <TextBlock Text="Stops monitoring and exits completely. Widgets also close."
                       FontSize="10" Foreground="#CCffffff"
                       TextWrapping="Wrap"/>
          </StackPanel>
        </Button>

      </Grid>

      <!-- Widget option (shown only if widget is visible) -->
      <CheckBox x:Name="HideWidgetCheck"
                Content="Also hide the Desktop Widget when minimizing to tray"
                FontSize="12"
                Foreground="{DynamicResource TextSecondaryBrush}"
                IsVisible="False"/>

      <!-- Remember -->
      <CheckBox x:Name="RememberCheck"
                Content="Remember my choice (can be changed in Settings)"
                FontSize="12"
                Foreground="{DynamicResource TextSecondaryBrush}"/>

    </StackPanel>
  </Border>

</Window>
