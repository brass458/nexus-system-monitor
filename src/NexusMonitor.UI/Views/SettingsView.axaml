<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             x:Class="NexusMonitor.UI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             x:CompileBindings="False">

  <UserControl.Resources>
    <!-- Minimal control theme for circular colour-swatch buttons -->
    <ControlTheme x:Key="SwatchTheme" TargetType="Button">
      <Setter Property="Template">
        <ControlTemplate>
          <Border Width="{TemplateBinding Width}"
                  Height="{TemplateBinding Height}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  Background="{TemplateBinding Background}"
                  Cursor="Hand"
                  Opacity="{TemplateBinding Opacity}">
            <Border.Transitions>
              <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.1"/>
              </Transitions>
            </Border.Transitions>
          </Border>
        </ControlTemplate>
      </Setter>
      <Style Selector="^:pointerover">
        <Setter Property="Opacity" Value="0.75"/>
      </Style>
      <Style Selector="^:pressed">
        <Setter Property="Opacity" Value="0.5"/>
      </Style>
    </ControlTheme>
  </UserControl.Resources>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
  <StackPanel Margin="24" Spacing="16">
    <TextBlock Text="Settings"
               FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
               Foreground="{StaticResource TextPrimaryBrush}"/>

    <!-- ===== APPEARANCE ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="12">
        <TextBlock Text="Appearance" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"/>
        <Separator/>

        <!-- Dark / Light theme toggle -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0">
            <TextBlock Text="Theme" FontSize="{DynamicResource NxFont13}"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Affects window chrome, text, and card backgrounds"
                       FontSize="{DynamicResource NxFont10}" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,2,0,0"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
            <ToggleButton Classes="nx-toggle"
                          Content="Dark"
                          IsChecked="{Binding IsDarkTheme}"/>
            <ToggleButton Classes="nx-toggle"
                          Content="Light"
                          IsChecked="{Binding IsDarkTheme, Converter={x:Static BoolConverters.Not}, Mode=OneWay}"
                          Command="{Binding SetLightThemeCommand}"/>
          </StackPanel>
        </Grid>

        <!-- Update Interval -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="Metrics Update Interval" FontSize="{DynamicResource NxFont13}"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Polling rate for all views and the overlay widget"
                       FontSize="{DynamicResource NxFont10}" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,2,0,0"/>
          </StackPanel>
          <ComboBox Grid.Column="1" Width="120" VerticalAlignment="Center"
                    ItemsSource="{x:Static vm:SettingsViewModel.UpdateIntervalLabels}"
                    SelectedIndex="{Binding UpdateIntervalIndex}"/>
        </Grid>

      </StackPanel>
    </Border>

    <!-- ===== TYPOGRAPHY ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="12">
        <TextBlock Text="Typography" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"/>
        <Separator/>

        <!-- Font family picker -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="Font Family" FontSize="{DynamicResource NxFont13}"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Applied to all windows and the overlay widget"
                       FontSize="{DynamicResource NxFont10}" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,2,0,0"/>
          </StackPanel>
          <ComboBox Grid.Column="1" Width="180" VerticalAlignment="Center"
                    MaxDropDownHeight="260"
                    ItemsSource="{x:Static vm:SettingsViewModel.SystemFonts}"
                    SelectedItem="{Binding FontFamily}"/>
        </Grid>

        <!-- Current font preview -->
        <Border Padding="12,8"
                Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="8">
          <TextBlock Text="The quick brown fox jumps over the lazy dog  0123456789"
                     FontSize="{DynamicResource NxFont12}"
                     FontFamily="{Binding FontFamily}"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- Font Scale slider -->
        <StackPanel Spacing="2" Margin="0,4,0,0">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="Font Size Scale" FontSize="{DynamicResource NxFont12}"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding FontScale, StringFormat='{}{0:P0}'}"
                       FontSize="{DynamicResource NxFont11}" Foreground="{StaticResource TextTertiaryBrush}"/>
          </Grid>
          <Slider Minimum="0.75" Maximum="1.5"
                  Value="{Binding FontScale}"
                  TickFrequency="0.05" IsSnapToTickEnabled="True"
                  Margin="0,2,0,0"/>
          <TextBlock Text="75% = compact  ·  100% = default  ·  150% = large"
                     FontSize="{DynamicResource NxFont10}" Foreground="{StaticResource TextTertiaryBrush}"
                     Margin="0,0,0,4"/>
        </StackPanel>

      </StackPanel>
    </Border>

    <!-- ===== ACCENT COLORS ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="12">
        <TextBlock Text="Accent Colors" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"/>
        <Separator/>

        <!-- Primary accent palette -->
        <TextBlock Text="PRIMARY ACCENT" FontSize="{DynamicResource NxFont11}" FontWeight="Medium" LetterSpacing="0.6"
                   Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,4"/>
        <TextBlock Text="Affects: buttons, chart lines, active nav item, toggle state, selections"
                   FontSize="{DynamicResource NxFont10}" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,4"/>

        <!-- Row of accent swatches with live accent-color mini-preview beside each -->
        <WrapPanel Orientation="Horizontal">
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#0A84FF"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#0A84FF"
                  ToolTip.Tip="Blue"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#BF5AF2"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#BF5AF2"
                  ToolTip.Tip="Purple"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#FF375F"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#FF375F"
                  ToolTip.Tip="Pink"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#FF9F0A"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#FF9F0A"
                  ToolTip.Tip="Orange"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#FFD60A"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#FFD60A"
                  ToolTip.Tip="Yellow"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#34C759"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#34C759"
                  ToolTip.Tip="Green"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#5AC8FA"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#5AC8FA"
                  ToolTip.Tip="Teal"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#FF453A"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#FF453A"
                  ToolTip.Tip="Red"/>
        </WrapPanel>

        <!-- Live preview row showing what the selected accent changes -->
        <Border Padding="12,8"
                Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="8">
          <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,16,0">
              <Border Width="10" Height="10" CornerRadius="5"
                      Background="{DynamicResource AccentBlueBrush}"
                      VerticalAlignment="Center"/>
              <TextBlock Text="Buttons" FontSize="{DynamicResource NxFont10}"
                         Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,16,0">
              <Border Width="10" Height="10" CornerRadius="2"
                      Background="{DynamicResource AccentBlueDimBrush}"
                      BorderBrush="{DynamicResource AccentBlueBrush}"
                      BorderThickness="1"
                      VerticalAlignment="Center"/>
              <TextBlock Text="Selections" FontSize="{DynamicResource NxFont10}"
                         Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,16,0">
              <Border Width="28" Height="10" CornerRadius="5"
                      Background="{DynamicResource AccentBlueBrush}"
                      VerticalAlignment="Center"/>
              <TextBlock Text="Nav" FontSize="{DynamicResource NxFont10}"
                         Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="Aa" FontSize="{DynamicResource NxFont11}" FontWeight="SemiBold"
                         Foreground="{DynamicResource AccentBlueBrush}"
                         VerticalAlignment="Center"/>
              <TextBlock Text="Links" FontSize="{DynamicResource NxFont10}"
                         Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
          </WrapPanel>
        </Border>

        <!-- Text accent sub-theme -->
        <TextBlock Text="TEXT ACCENT" FontSize="{DynamicResource NxFont11}" FontWeight="Medium" LetterSpacing="0.6"
                   Foreground="{StaticResource TextTertiaryBrush}" Margin="0,8,0,4"/>
        <TextBlock Text="Separate color for highlighted text, links, and active labels. Leave empty to derive from primary accent."
                   FontSize="{DynamicResource NxFont10}" Foreground="{StaticResource TextTertiaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,4"/>
        <WrapPanel Orientation="Horizontal">
          <!-- Same swatches as primary, setting text accent instead -->
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="Transparent"
                  BorderBrush="{StaticResource BorderSubtleBrush}"
                  ToolTip.Tip="Derive from Primary (default)">
            <Button.Styles>
              <Style Selector="Button">
                <Setter Property="BorderThickness" Value="1"/>
              </Style>
            </Button.Styles>
          </Button>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#0A84FF"
                  CommandParameter="#0A84FF" ToolTip.Tip="Blue"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#BF5AF2"
                  CommandParameter="#BF5AF2" ToolTip.Tip="Purple"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#FF375F"
                  CommandParameter="#FF375F" ToolTip.Tip="Pink"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#FF9F0A"
                  CommandParameter="#FF9F0A" ToolTip.Tip="Orange"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#34C759"
                  CommandParameter="#34C759" ToolTip.Tip="Green"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#5AC8FA"
                  CommandParameter="#5AC8FA" ToolTip.Tip="Teal"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#FF453A"
                  CommandParameter="#FF453A" ToolTip.Tip="Red"/>
        </WrapPanel>
        <!-- Text accent preview -->
        <TextBlock FontSize="{DynamicResource NxFont11}" Margin="0,2,0,0">
          <Run Text="Sample text — " Foreground="{StaticResource TextSecondaryBrush}"/>
          <Run Text="highlighted text uses TextAccent"
               Foreground="{DynamicResource TextAccentBrush}"
               FontWeight="SemiBold"/>
        </TextBlock>

        <!-- ── Custom Color Picker (opens isolated popup window) ──────── -->
        <TextBlock Text="CUSTOM COLOR PICKER" FontSize="{DynamicResource NxFont11}" FontWeight="Medium" LetterSpacing="0.6"
                   Foreground="{StaticResource TextTertiaryBrush}" Margin="0,12,0,6"/>
        <Grid ColumnDefinitions="*,10,Auto">
          <!-- Current-accent swatch + hex label -->
          <Border Grid.Column="0" Height="34" CornerRadius="8"
                  Background="{DynamicResource AccentBlueBrush}"
                  Padding="12,0">
            <TextBlock Text="{Binding AccentColorHex}"
                       FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                       Foreground="White"
                       VerticalAlignment="Center"/>
          </Border>
          <!-- Open picker dialog -->
          <Button Grid.Column="2"
                  Classes="nx-btn"
                  Click="OnPickColorClick"
                  ToolTip.Tip="Open color wheel picker">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="🎨" FontSize="{DynamicResource NxFont12}" VerticalAlignment="Center"/>
              <TextBlock Text="Pick Color…" FontSize="{DynamicResource NxFont12}" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </Grid>

      </StackPanel>
    </Border>

    <!-- ===== LIQUID GLASS ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="12">
        <TextBlock Text="Liquid Glass" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"/>
        <Separator/>

        <!-- Main glass toggle -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0">
            <TextBlock Text="Liquid Glass Effect" FontSize="{DynamicResource NxFont13}"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Full-window refraction with specular rim lights and OS backdrop blur"
                       FontSize="{DynamicResource NxFont11}" Foreground="{StaticResource TextTertiaryBrush}"
                       TextWrapping="Wrap" Margin="0,2,0,0"/>
          </StackPanel>
          <ToggleButton Grid.Column="1" Classes="nx-toggle" IsChecked="{Binding IsGlassEnabled}"
                        VerticalAlignment="Center"/>
        </Grid>

        <!-- Glass Opacity slider -->
        <StackPanel IsEnabled="{Binding IsGlassEnabled}" Spacing="2">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="Glass Opacity" FontSize="{DynamicResource NxFont12}"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBlock Grid.Column="1" Text="{Binding GlassOpacity, StringFormat='{}{0:P0}'}"
                       FontSize="{DynamicResource NxFont11}" Foreground="{StaticResource TextTertiaryBrush}"/>
          </Grid>
          <Slider Minimum="0.0" Maximum="1.0" Value="{Binding GlassOpacity}"
                  TickFrequency="0.05" IsSnapToTickEnabled="True"
                  Margin="0,2,0,0"/>
          <TextBlock Text="0% = fully see-through  ·  100% = solid"
                     FontSize="{DynamicResource NxFont10}" Foreground="{StaticResource TextTertiaryBrush}"
                     Margin="0,0,0,4"/>
        </StackPanel>

        <!-- Backdrop blur mode -->
        <Grid ColumnDefinitions="*,Auto" IsEnabled="{Binding IsGlassEnabled}">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="Backdrop Blur Mode" FontSize="{DynamicResource NxFont12}"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBlock Text="Acrylic: Win 10/11  ·  Mica: Win 11+  ·  Blur: legacy"
                       FontSize="{DynamicResource NxFont10}" Foreground="{StaticResource TextTertiaryBrush}"
                       Margin="0,2,0,0"/>
          </StackPanel>
          <ComboBox Grid.Column="1" Width="110" VerticalAlignment="Center"
                    ItemsSource="{x:Static vm:SettingsViewModel.BackdropModes}"
                    SelectedItem="{Binding BackdropBlurMode}"/>
        </Grid>

        <!-- Specular highlights sub-section -->
        <TextBlock Text="SPECULAR HIGHLIGHTS" FontSize="{DynamicResource NxFont11}" FontWeight="Medium" LetterSpacing="0.6"
                   Foreground="{StaticResource TextTertiaryBrush}" Margin="0,4,0,4"/>
        <StackPanel IsEnabled="{Binding IsGlassEnabled}" Spacing="8">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0">
              <TextBlock Text="Specular Rim Lights" FontSize="{DynamicResource NxFont13}"
                         Foreground="{StaticResource TextPrimaryBrush}"/>
              <TextBlock Text="3-layer white edge glow (wash + sharp rim + prismatic shimmer)"
                         FontSize="{DynamicResource NxFont11}" Foreground="{StaticResource TextTertiaryBrush}"
                         TextWrapping="Wrap" Margin="0,2,0,0"/>
            </StackPanel>
            <ToggleButton Grid.Column="1" Classes="nx-toggle" IsChecked="{Binding IsSpecularEnabled}"
                          VerticalAlignment="Center"/>
          </Grid>
          <StackPanel IsEnabled="{Binding IsSpecularEnabled}" Spacing="2">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="Intensity" FontSize="{DynamicResource NxFont12}"
                         Foreground="{StaticResource TextSecondaryBrush}"/>
              <TextBlock Grid.Column="1" Text="{Binding SpecularIntensity, StringFormat='{}{0:P0}'}"
                         FontSize="{DynamicResource NxFont11}" Foreground="{StaticResource TextTertiaryBrush}"/>
            </Grid>
            <Slider Minimum="0.0" Maximum="1.0" Value="{Binding SpecularIntensity}"
                    TickFrequency="0.05" IsSnapToTickEnabled="True"
                    Margin="0,2,0,4"/>
          </StackPanel>
        </StackPanel>

      </StackPanel>
    </Border>

    <!-- ===== DESKTOP OVERLAY ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="12">
        <TextBlock Text="Desktop Overlay" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"/>
        <Separator/>
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0">
            <TextBlock Text="Floating Monitor Widget" FontSize="{DynamicResource NxFont13}"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Always-on-top overlay — CPU, RAM, network, GPU. Mirrors main glass settings."
                       FontSize="{DynamicResource NxFont11}" Foreground="{StaticResource TextTertiaryBrush}"
                       TextWrapping="Wrap" Margin="0,2,0,0"/>
          </StackPanel>
          <ToggleButton Grid.Column="1" Classes="nx-toggle" IsChecked="{Binding ShowOverlayWidget}"
                        VerticalAlignment="Center"/>
        </Grid>
      </StackPanel>
    </Border>

    <!-- ===== NOTIFICATIONS ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="12">
        <TextBlock Text="Notifications" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"/>
        <Separator/>
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0">
            <TextBlock Text="Desktop Alert Notifications" FontSize="{DynamicResource NxFont13}"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Show a Windows toast when an alert rule threshold is triggered"
                       FontSize="{DynamicResource NxFont11}" Foreground="{StaticResource TextTertiaryBrush}"
                       TextWrapping="Wrap" Margin="0,2,0,0"/>
          </StackPanel>
          <ToggleButton Grid.Column="1" Classes="nx-toggle"
                        IsChecked="{Binding DesktopNotificationsEnabled}"
                        VerticalAlignment="Center"/>
        </Grid>
      </StackPanel>
    </Border>

    <!-- ===== SYSTEM TRAY ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="12">
        <TextBlock Text="System Tray" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"/>
        <Separator/>

        <!-- Close behaviour -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="When Pressing the Close Button" FontSize="{DynamicResource NxFont13}"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Default action when you click the × button on the main window"
                       FontSize="{DynamicResource NxFont10}" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,2,0,0"/>
          </StackPanel>
          <ComboBox Grid.Column="1" Width="180" VerticalAlignment="Center"
                    ItemsSource="{x:Static vm:SettingsViewModel.CloseActionLabels}"
                    SelectedIndex="{Binding CloseActionIndex}"/>
        </Grid>

        <!-- Hide widget on minimize -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0">
            <TextBlock Text="Hide Widget When Minimizing to Tray" FontSize="{DynamicResource NxFont13}"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Hides the desktop overlay widget when the app goes to tray"
                       FontSize="{DynamicResource NxFont10}" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,2,0,0"/>
          </StackPanel>
          <ToggleButton Grid.Column="1" Classes="nx-toggle"
                        IsChecked="{Binding HideWidgetOnMinimize}"
                        VerticalAlignment="Center"/>
        </Grid>

        <TextBlock Text="Tip: Right-click the tray icon for quick access to Show / Widget / Exit"
                   FontSize="{DynamicResource NxFont10}" Foreground="{StaticResource TextTertiaryBrush}"
                   TextWrapping="Wrap"/>

      </StackPanel>
    </Border>

    <!-- ===== ABOUT ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="4">
        <TextBlock Text="Nexus Monitor" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"/>
        <TextBlock Text="Version 0.1.0 — Phase 6 (Per-Device Performance + Liquid Glass)"
                   FontSize="{DynamicResource NxFont11}" Foreground="{StaticResource TextTertiaryBrush}"/>
        <TextBlock Text="MIT License · Open Source · Cross-Platform"
                   FontSize="{DynamicResource NxFont11}" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,4,0,0"/>
      </StackPanel>
    </Border>

  </StackPanel>
  </ScrollViewer>

</UserControl>
