<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexusMonitor.UI.ViewModels"
        xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
        x:Class="NexusMonitor.UI.Views.OverlayWindow"
        x:DataType="vm:OverlayViewModel"
        x:CompileBindings="False"
        SystemDecorations="None"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Transparent"
        Width="240"
        Height="188"
        CanResize="True">

  <!-- Outer panel holds glass background + specular layers stacked together -->
  <Panel>

    <!-- Glass surface border -->
    <Border Background="{DynamicResource OverlayBgBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            BoxShadow="inset 0 1 3 0 #18FFFFFF, 0 4 24 0 #60000000"
            Padding="14,12"
            PointerPressed="OnDrag">
      <StackPanel Spacing="8">

        <!-- CPU row: label + sparkline + value -->
        <Grid ColumnDefinitions="34,*,48">
          <TextBlock Grid.Column="0"
                     Text="CPU"
                     FontSize="{DynamicResource NxFont10}" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     VerticalAlignment="Center"/>
          <lvc:CartesianChart Grid.Column="1"
                              Series="{Binding CpuSeries}"
                              XAxes="{Binding CpuXAxes}"
                              YAxes="{Binding CpuYAxes}"
                              Height="26"
                              Background="Transparent"
                              AnimationsSpeed="0:0:0"
                              ZoomMode="None"
                              EasingFunction="{x:Null}"/>
          <TextBlock Grid.Column="2"
                     Text="{Binding CpuDisplay}"
                     FontSize="{DynamicResource NxFont13}" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Center"/>
        </Grid>

        <!-- RAM row: label + value on same line, then progress bar below -->
        <StackPanel Spacing="3">
          <Grid ColumnDefinitions="34,*,Auto">
            <TextBlock Grid.Column="0"
                       Text="RAM"
                       FontSize="{DynamicResource NxFont10}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2"
                       Text="{Binding MemDisplay}"
                       FontSize="{DynamicResource NxFont10}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"/>
          </Grid>
          <ProgressBar Value="{Binding MemPercent}"
                       Minimum="0" Maximum="100"
                       Height="4"
                       Margin="34,0,0,0"/>
        </StackPanel>

        <!-- Network rows -->
        <Grid ColumnDefinitions="34,*">
          <TextBlock Grid.Column="0"
                     Text="NET"
                     FontSize="{DynamicResource NxFont10}" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     VerticalAlignment="Top"/>
          <StackPanel Grid.Column="1" Spacing="2">
            <TextBlock Text="{Binding NetRecvDisplay}"
                       FontSize="{DynamicResource NxFont10}"
                       Foreground="{StaticResource ProcDotNetBrush}"/>
            <TextBlock Text="{Binding NetSendDisplay}"
                       FontSize="{DynamicResource NxFont10}"
                       Foreground="{StaticResource ColorDangerBrush}"/>
          </StackPanel>
        </Grid>

        <!-- GPU row (hidden when no GPU) -->
        <Grid ColumnDefinitions="34,*,48"
              IsVisible="{Binding HasGpu}">
          <TextBlock Grid.Column="0"
                     Text="GPU"
                     FontSize="{DynamicResource NxFont10}" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     VerticalAlignment="Center"/>
          <TextBlock Grid.Column="2"
                     Text="{Binding GpuDisplay}"
                     FontSize="{DynamicResource NxFont13}" FontWeight="Bold"
                     Foreground="{StaticResource ColorWarningBrush}"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Center"/>
        </Grid>

        <!-- Active Profile label (shown only when a profile is active) -->
        <TextBlock Text="{Binding ActiveProfileName, StringFormat='⚡ {0}'}"
                   FontSize="{DynamicResource NxFont09}"
                   FontWeight="Medium"
                   Foreground="{DynamicResource AccentBrush}"
                   HorizontalAlignment="Center"
                   IsVisible="{Binding HasActiveProfile}"
                   Margin="0,2,0,0"/>

      </StackPanel>
    </Border>

    <!-- ── Crystal Glass specular stack (pointer-transparent) ── -->

    <!-- Layer 1: Broad soft wash -->
    <Border IsHitTestVisible="False"
            CornerRadius="14"
            ClipToBounds="True"
            Opacity="{DynamicResource GlassSpecularOpacity}">
      <Border.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
          <GradientStop Color="#50FFFFFF" Offset="0"/>
          <GradientStop Color="#18FFFFFF" Offset="0.4"/>
          <GradientStop Color="#00FFFFFF" Offset="0.8"/>
        </LinearGradientBrush>
      </Border.Background>
    </Border>

    <!-- Layer 2: Sharp top rim line -->
    <Border IsHitTestVisible="False"
            CornerRadius="14,14,0,0"
            Height="5"
            VerticalAlignment="Top"
            Opacity="{DynamicResource GlassSpecularOpacity}">
      <Border.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
          <GradientStop Color="#D0FFFFFF" Offset="0"/>
          <GradientStop Color="#50FFFFFF" Offset="0.5"/>
          <GradientStop Color="#00FFFFFF" Offset="1"/>
        </LinearGradientBrush>
      </Border.Background>
    </Border>

    <!-- Layer 3: Prismatic shimmer -->
    <Border IsHitTestVisible="False"
            CornerRadius="14"
            ClipToBounds="True"
            Opacity="{DynamicResource GlassSpecularOpacity}">
      <Border.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
          <GradientStop Color="#0CFF8888" Offset="0.0"/>
          <GradientStop Color="#06FFFFFF" Offset="0.33"/>
          <GradientStop Color="#0C88FFFF" Offset="0.66"/>
          <GradientStop Color="#00FFFFFF" Offset="1.0"/>
        </LinearGradientBrush>
      </Border.Background>
    </Border>

  </Panel>

</Window>
