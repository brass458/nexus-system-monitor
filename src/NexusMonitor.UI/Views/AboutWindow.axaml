<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NexusMonitor.UI.Views.AboutWindow"
        Title="About Nexus System Monitor"
        Width="380"
        SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBaseBrush}">

  <Border Padding="32,28"
          Background="{DynamicResource BgPrimaryBrush}"
          BorderBrush="{DynamicResource GlassBorderBrush}"
          BorderThickness="1">
    <StackPanel Spacing="0" HorizontalAlignment="Center">

      <!-- App icon -->
      <Image Source="avares://NexusMonitor/Assets/nexus-icon-256.png"
             Width="96" Height="96"
             HorizontalAlignment="Center"
             Margin="0,0,0,20"/>

      <!-- App name -->
      <TextBlock Text="Nexus System Monitor"
                 FontSize="{DynamicResource NxFont16}"
                 FontWeight="Bold"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,6"/>

      <!-- Version (set from code-behind) -->
      <TextBlock x:Name="VersionText"
                 FontSize="{DynamicResource NxFont13}"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,4"/>

      <!-- Copyright + license -->
      <TextBlock Text="Copyright © 2026 TheBlackSwordsman"
                 FontSize="{DynamicResource NxFont11}"
                 Foreground="{DynamicResource TextTertiaryBrush}"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,2"/>
      <TextBlock Text="MIT License · Open Source · Cross-Platform"
                 FontSize="{DynamicResource NxFont11}"
                 Foreground="{DynamicResource TextTertiaryBrush}"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,24"/>

      <Separator Margin="0,0,0,20"/>

      <!-- Action buttons -->
      <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
        <Button Classes="nx-btn" Click="OnGitHubClick" Padding="16,7">
          <TextBlock Text="View on GitHub" FontSize="{DynamicResource NxFont12}"/>
        </Button>
        <Button Classes="nx-btn" Click="OnCloseClick" Padding="16,7">
          <TextBlock Text="Close" FontSize="{DynamicResource NxFont12}"/>
        </Button>
      </StackPanel>

    </StackPanel>
  </Border>

</Window>
