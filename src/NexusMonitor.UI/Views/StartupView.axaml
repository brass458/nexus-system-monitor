<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             xmlns:conv="using:NexusMonitor.UI.Converters"
             x:Class="NexusMonitor.UI.Views.StartupView"
             x:DataType="vm:StartupViewModel"
             x:CompileBindings="False">

  <UserControl.Resources>
    <conv:BoolToEnabledTextConverter x:Key="BoolEnabled"/>
    <conv:BoolToEnabledBrushConverter x:Key="BoolEnabledBrush"/>
  </UserControl.Resources>

  <DockPanel>

    <!-- Toolbar -->
    <Border DockPanel.Dock="Top"
            Padding="16,10"
            Background="{StaticResource BgSecondaryBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left"
                   Text="Startup Programs"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   VerticalAlignment="Center"
                   Margin="0,0,16,0"/>

        <Button DockPanel.Dock="Right"
                Classes="nx-btn"
                Command="{Binding RefreshCommand}"
                Margin="8,0,0,0"
                ToolTip.Tip="Refresh list">
          <TextBlock Text="↺  Refresh" FontSize="12"/>
        </Button>

        <Button DockPanel.Dock="Right"
                Classes="nx-btn"
                Command="{Binding ToggleEnabledCommand}"
                IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}"
                ToolTip.Tip="Enable or disable selected startup item">
          <TextBlock Text="Toggle" FontSize="12"/>
        </Button>

        <TextBox DockPanel.Dock="Right"
                 Classes="nx-input"
                 Text="{Binding SearchText}"
                 Watermark="Search name, publisher, command…"
                 Width="260"
                 VerticalAlignment="Center"/>
      </DockPanel>
    </Border>

    <!-- Status bar -->
    <Border DockPanel.Dock="Bottom"
            Padding="16,6"
            Background="{StaticResource BgSecondaryBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="0,1,0,0">
      <DockPanel>

        <!-- Error message — right-aligned, hidden when empty -->
        <TextBlock DockPanel.Dock="Right"
                   Text="{Binding LastError}"
                   IsVisible="{Binding LastError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   FontSize="11"
                   Foreground="{StaticResource ColorDangerBrush}"
                   VerticalAlignment="Center"/>

        <StackPanel Orientation="Horizontal" Spacing="24">
          <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
            <Run Text="Total: "/>
            <Run Text="{Binding TotalCount}"   Foreground="{StaticResource TextPrimaryBrush}"  FontWeight="Medium"/>
          </TextBlock>
          <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
            <Run Text="Enabled: "/>
            <Run Text="{Binding EnabledCount}" Foreground="{StaticResource ColorSuccessBrush}" FontWeight="Medium"/>
          </TextBlock>
        </StackPanel>

      </DockPanel>
    </Border>

    <!-- Table + loading overlay -->
    <Panel>

      <DataGrid Classes="nx-grid"
                ItemsSource="{Binding Items}"
                SelectedItem="{Binding SelectedItem}"
                AutoGenerateColumns="False"
                CanUserSortColumns="True"
                CanUserResizeColumns="True"
                IsReadOnly="True">
        <DataGrid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Enable"             Command="{Binding EnableItemCommand}"/>
            <MenuItem Header="Disable"            Command="{Binding DisableItemCommand}"/>
            <Separator/>
            <MenuItem Header="Open File Location" Command="{Binding OpenFileLocationCommand}"/>
            <MenuItem Header="Open Registry Key"  Command="{Binding OpenRegistryKeyCommand}"/>
          </ContextMenu>
        </DataGrid.ContextMenu>
        <DataGrid.Columns>

          <!-- Status badge -->
          <DataGridTemplateColumn Header="Status" Width="82" SortMemberPath="IsEnabled">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Border CornerRadius="4"
                        Padding="6,2"
                        Margin="4,3"
                        HorizontalAlignment="Center"
                        Background="{Binding IsEnabled, Converter={StaticResource BoolEnabledBrush}}">
                  <TextBlock Text="{Binding IsEnabled, Converter={StaticResource BoolEnabled}}"
                             FontSize="10" FontWeight="Medium"
                             Foreground="White"
                             HorizontalAlignment="Center"/>
                </Border>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTextColumn Header="Name"      Binding="{Binding Name}"      Width="200" IsReadOnly="True"/>
          <DataGridTextColumn Header="Publisher" Binding="{Binding Publisher}" Width="180" IsReadOnly="True"/>
          <DataGridTextColumn Header="Location"  Binding="{Binding Location}"  Width="160" IsReadOnly="True"/>
          <DataGridTextColumn Header="Command"   Binding="{Binding Command}"   Width="*"   IsReadOnly="True"/>

        </DataGrid.Columns>
      </DataGrid>

      <!-- Loading overlay -->
      <Border IsVisible="{Binding IsLoading}"
              Background="#80000000">
        <TextBlock Text="Loading startup items…"
                   FontSize="14"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
      </Border>

    </Panel>

  </DockPanel>

</UserControl>
